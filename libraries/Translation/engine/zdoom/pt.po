msgid "SWSTRING"
msgstr "Apenas disponível na versão registrada"

msgid "DOSY"
msgstr "(Carrega Y para sair)"

msgid "QUITMSG1"
msgstr ""
"Por favor não te vás embora, há mais\n"
"demônios para matar!"

msgid "QUITMSG2"
msgstr ""
"Falando a sério—Isto está se a tornar\n"
"num banho de sangue!"

msgid "QUITMSG3"
msgstr ""
"Se fosse a ti não saia daqui.\n"
"O DOS é bem pior."

msgid "QUITMSG4"
msgstr ""
"Quer dizer que gosta mais\n"
"do DOS do que eu, é isso?"

msgid "QUITMSG5"
msgstr ""
"Não te vás embora agora—Está um\n"
"demônio ao virar da esquina!"

msgid "QUITMSG6"
msgstr ""
"Sabes, da próxima vez que vieres para\n"
"aqui vou te fazer explodir em bocadinhos."

msgid "QUITMSG7"
msgstr "Vai te em embora. Vê lá se eu quero saber."

# More info here.
msgid "QUITMSG8"
msgstr ""
"Queres sair?\n"
"Só podes ter perdido a cabeça!"

# A “dimensional shambler” is a creature appearing in the works of H. P.
# Lovecraft.
msgid "QUITMSG9"
msgstr ""
"Não saias agora, há um\n"
"monstro de outra dimensão à tua\n"
"espera no DOS!"

msgid "QUITMSG10"
msgstr ""
"Desaparece daqui e volta\n"
"para os teus programas chatos."

msgid "QUITMSG11"
msgstr ""
"Se eu fosse o teu chefe, lutava\n"
"num deathmatch contigo agora mesmo!"

msgid "QUITMSG12"
msgstr ""
"Olha, se saires agora perdes\n"
"a tua contagem de mortes!"

msgid "QUITMSG13"
msgstr ""
"Sai daqui. Quando voltar,\n"
"vou estar à espera com um taco."

msgid "QUITMSG14"
msgstr ""
"Tens muita sorte em eu não te dar um excerto\n"
"de porrada por teres pensado em sair."

msgid "QUITMSG15"
msgstr ""
"Para onde estás a ir?!\n"
"E então a rebelião?"

msgid "QUITMSG16"
msgstr ""
"Massacre interrompido…\n"
"Que provocante!"

msgid "QUITMSG17"
msgstr ""
"Mas tu és a nossa esperança\n"
"—a minha única chance!!"

msgid "QUITMSG18"
msgstr "Ninguém vira as costas para a Blackbird."

msgid "QUITMSG19"
msgstr "Eu achei que eras diferente…"

msgid "QUITMSG20"
msgstr "Pronto! Mata e foge!"

msgid "QUITMSG21"
msgstr ""
"Podes sair…\n"
"mas não te podes esconder…"

msgid "QUITMSG22"
msgstr ""
"Qual é o problema?\n"
"A mamã chamou para o jantar?"

msgid "QUITMSG23"
msgstr ""
"Não desistas agora! Ainda há\n"
"flemoids à solta!"

msgid "QUITMSG24"
msgstr ""
"Não desistas—os flemóides\n"
"estão a ganhar!"

msgid "QUITMSG25"
msgstr ""
"Não te vás embora agora.\n"
"Nós precisamos da tua ajuda!"

msgid "QUITMSG26"
msgstr ""
"Espero que só estejas a fazer uma\n"
"pausa pra um Chex® Party Mix."

msgid "QUITMSG27"
msgstr ""
"Não saias agora!\n"
"Nós precisamos da tua ajuda!"

msgid "QUITMSG28"
msgstr ""
"Não abandone a\n"
"Federação Intergaláctica de Cereais!"

msgid "QUITMSG29"
msgstr ""
"O verdadeiro Guerreiro Chex®\n"
"não desistiria tão rapido!"

