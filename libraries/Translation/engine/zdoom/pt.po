msgid "QUITMSG"
msgstr ""
"Tem a certeza que deseja sair \n"
"deste excelente jogo?"

# In some languages, it may make more sense to translate “Press a key” as
# “Press any key.”
msgid "LOADNET"
msgstr ""
"Não pode carregar um jogo durante um jogo em rede!\n"
"\n"
"Carrega numa tecla qualquer."

msgid "QLOADNET"
msgstr ""
"Não pode carregar um quickload durante um jogo em rede!\n"
"\n"
"Carrega numa tecla qualquer."

msgid "QSAVESPOT"
msgstr ""
"Você ainda não escolheu um slot de quicksave!\n"
"\n"
"Carrega numa tecla qualquer."

msgid "NEWGAME"
msgstr ""
"Não podes iniciar um novo jogo\n"
"durante um jogo em rede.\n"
"\n"
"Carrega numa tecla qualquer."

msgid "NIGHTMARE"
msgstr ""
"Tem a certeza? Este nível de dificuldade\n"
"está longe de ser um pouco justo.\n"
"\n"
"Carrega Y ou N."

msgid "SWSTRING"
msgstr ""
"Esta é a versão shareware de Doom.\n"
"\n"
"Precisas de obter a trilogia completa.\n"
"\n"
"Carrega numa tecla qualquer."

msgid "NETEND"
msgstr ""
"Não podes terminar um jogo em rede!\n"
"\n"
"Carrega numa tecla qualquer."

msgid "ENDGAME"
msgstr ""
"Tem certeza que deseja fechar este jogo?\n"
"\n"
"Carrega Y ou N."

msgid "RAVENQUITMSG"
msgstr "Tens a certeza que queres sair?"

