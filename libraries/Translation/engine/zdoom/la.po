msgid "QUITMSG1"
msgstr ""
"Quaeso ne derelinquas, illic 'magis\n"
"daemones tosti!"

msgid "QUITMSG2"
msgstr ""
"Lets beat hoc, quod versatur\n"
"in sanguine!"

msgid "QUITMSG3"
msgstr ""
"Non relinquerem si te essem.\n"
"DOS multo pejora."

msgid "QUITMSG4"
msgstr ""
"Tu es conatur dicere sicut DOS\n"
"melius me ius?"

msgid "QUITMSG5"
msgstr ""
"Noli adhuc ibi a\n"
"daemon circa angulum!"

msgid "QUITMSG6"
msgstr ""
"Ya scis, iterum huc venisti\n"
"Im 'agnus tosti ya."

msgid "QUITMSG7"
msgstr "Perge et discede. vide si curo."

msgid "QUITMSG8"
msgstr ""
"Quit vis?\n"
"Tum octavam perdidisti."

msgid "QUITMSG9"
msgstr ""
"Noli nunc ire, illic 'a' \n"
"shambler exspectans dimensiva\n"
"ad DOS prompt!"

msgid "QUITMSG10"
msgstr ""
"Get outta hic et vade retro\n"
"ad taediosum progressio."

msgid "QUITMSG11"
msgstr ""
"Si essem bulla tua, vellem \n"
"deathmatch ya in a minute!"

msgid "QUITMSG12"
msgstr ""
"Vide, bud. nunc exeatis\n"
"et corpus amittis comitem!"

msgid "QUITMSG13"
msgstr ""
"Modo discede. Cum veneris\n"
"redi, opperiar vespertilio."

msgid "QUITMSG14"
msgstr ""
"Sis felix non sapere\n"
"te ad cogitandum de relinquendo."

msgid "QUITMSG15"
msgstr ""
"Quo vadis?!\n"
"Quid de rebellione?"

msgid "QUITMSG16"
msgstr ""
"Caedes interruptus…\n"
"Quid vexas!"

msgid "QUITMSG17"
msgstr ""
"Sed tu spes\n"
"—my tantum possibilitas!!"

msgid "QUITMSG18"
msgstr "Nemo in Merula ambulat."

msgid "QUITMSG19"
msgstr "Cogitavi te differre …"

msgid "QUITMSG20"
msgstr "Bene! tantum occide et curre!"

msgid "QUITMSG21"
msgstr ""
"Potes quieti…\n"
"sed non potes celare…"

msgid "QUITMSG22"
msgstr ""
"Whaaa, quid negotist?\n"
"Mammam cenam dicit?"

msgid "QUITMSG23"
msgstr ""
"Noli nunc decedere, adhuc sunt\n"
"flemoids in solutam!"

msgid "QUITMSG24"
msgstr ""
"Noli tradere, flemoids will\n"
"supero!"

msgid "QUITMSG25"
msgstr ""
"Ne nunc relinquas.\n"
"Auxilium tuum nobis opus est!"

msgid "QUITMSG26"
msgstr ""
"Spero vos erant 'iustus taking\n"
"conteram enim Chex® factionis misce."

msgid "QUITMSG27"
msgstr ""
"Ne nunc discedas!\n"
"Auxilium tuum nobis opus est!"

msgid "QUITMSG28"
msgstr ""
"Ne derelinquas\n"
"Foederatio intergalactica frugum!"

msgid "QUITMSG29"
msgstr ""
"Verus Chex® bellator\n"
"non tam celeriter!"

