msgid "QUITMSG"
msgstr ""
"Voulez-vous vraiment\n"
"quitter cet excellent jeu ?"

# In some languages, it may make more sense to translate “Press a key” as
# “Press any key.”
msgid "LOADNET"
msgstr ""
"Impossible de charger une partie\n"
"pendant une partie en réseau!\n"
"Appuyez sur une touche."

msgid "QLOADNET"
msgstr ""
"Chargement rapide impossible\n"
"pendant une partie en réseau!\n"
"Appuyez sur une touche."

msgid "QSAVESPOT"
msgstr ""
"Vous n'avez pas encore choisi un\n"
"emplacement de sauvegarde!\n"
"Appuyez sur une touche."

msgid "NEWGAME"
msgstr ""
"Vous ne pouvez pas lancer\n"
"une nouvelle partie lors d'une\n"
"partie en réseau.\n"
"Appuyez sur une touche."

msgid "NIGHTMARE"
msgstr ""
"Vous êtes sûr ? Ce niveau de\n"
"difficulté est vraiment impitoyable !\n"
"\n"
"Appuyez sur Y ou N."

msgid "SWSTRING"
msgstr ""
"Votre version de Doom est une version shareware.\n"
"\n"
"Vous devez commander la version complète.\n"
"\n"
"Appuyez sur une touche."

msgid "NETEND"
msgstr ""
"Vous ne pouvez pas mettre fin à une partie en réseau!\n"
"\n"
"Appuyez sur une touche."

msgid "ENDGAME"
msgstr ""
"Voulez vous mettre fin à votre partie?\n"
"\n"
"Appuyez sur Y ou N."

msgid "RAVENQUITMSG"
msgstr "Êtes vous sûr de vouloir quitter ?"

msgctxt "heretic"
msgid "SWSTRING"
msgstr "Disponible uniquement dans la version enregistrée"

msgid "DOSY"
msgstr "(Appuyez sur Y pour quitter)"

msgid "QUITMSG1"
msgstr ""
"Ne partez pas, il y a encore\n"
"des démons a buter !"

msgid "QUITMSG2"
msgstr ""
"Fichons le camp, ça dégénère\n"
"en bain de sang !"

msgid "QUITMSG3"
msgstr ""
"Je ne quitterais pas si j'étais vous.\n"
"Votre OS est bien pire."

msgid "QUITMSG4"
msgstr ""
"Vous essayez de dire que vous aimez DOS\n"
"mieux que moi, pas vrai ?"

msgid "QUITMSG5"
msgstr ""
"Ne partez pas encore ! Il y a\n"
"un démon dans le coin !"

msgid "QUITMSG6"
msgstr ""
"Vous savez, la prochaine fois que vous revenez,\n"
"je vous grille."

msgid "QUITMSG7"
msgstr "Allez y, partez, allez voir si j'y suis."

# More info here.
msgid "QUITMSG8"
msgstr ""
"Vous voulez vraiment quitter ?\n"
"Vous avez vraiment perdu vos vertus !"

# A “dimensional shambler” is a creature appearing in the works of H. P.
# Lovecraft.
msgid "QUITMSG9"
msgstr ""
"Ne partez pas maintenant, il y a un\n"
"monstre interdimensionnel qui\n"
"dans attend dans votre OS !"

msgid "QUITMSG10"
msgstr ""
"Tirez vous de là et retournez\n"
"à vos programmes ennuyeux."

msgid "QUITMSG11"
msgstr ""
"Si j'étais votre patron, je vous\n"
"collerai un Deathmatch dans la minute !"

msgid "QUITMSG12"
msgstr ""
"Regardez, l'ami. Vous partez maintenant\n"
"et vous pouvez oublier votre score !"

msgid "QUITMSG13"
msgstr ""
"Allez, partez. Quand vous reviendrez,\n"
"je vous attendrai avec une batte."

msgid "QUITMSG14"
msgstr ""
"Vous êtes chanceux que je ne vous en \n"
"colle pas une parce que vous pensez partir."

msgid "QUITMSG15"
msgstr ""
"Où allez vous ?\n"
"Que va devenir la rébellion ?"

msgid "QUITMSG16"
msgstr ""
"Carnage interruptus…\n"
"Tout un programme !"

msgid "QUITMSG17"
msgstr ""
"Mais vous êtes l'espoir,\n"
"mon unique chance !!"

msgid "QUITMSG18"
msgstr "Personne n'abandonne Blackbird."

msgid "QUITMSG19"
msgstr "Je vous croyais différent…"

msgid "QUITMSG20"
msgstr "C'est ça ! Tuez n'importe-qui et barrez-vous comme ça !"

msgid "QUITMSG21"
msgstr ""
"Vous pouvez partir…\n"
"Mais vous ne pouvez pas vous cacher…"

msgid "QUITMSG22"
msgstr ""
"Bah, il est où est le problème ?\n"
"Maman a dit « à table ! » ?"

msgid "QUITMSG23"
msgstr ""
"N'abandonnez pas maintenant,\n"
"les flémoides sont toujours à l'assaut !"

msgid "QUITMSG24"
msgstr ""
"Ne partez pas, ou les\n"
"Flémoïdes vont nous battre !"

msgid "QUITMSG25"
msgstr ""
"Ne partez pas.\n"
"Nous avons besoin de votre aide !"

msgid "QUITMSG26"
msgstr ""
"J'espère que tu prends une pause\n"
"pour un bol de Chex® Party Mix."

msgid "QUITMSG27"
msgstr ""
"Restez avec nous !\n"
"Nous avons besoin de vous !"

msgid "QUITMSG28"
msgstr ""
"N'abandonnez pas la\n"
"Fédération Intergalactique des Céréales !"

msgid "QUITMSG29"
msgstr ""
"Le vrai Chex® Warrior\n"
"n'abandonnerait pas de si tôt !"

