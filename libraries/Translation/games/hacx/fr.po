msgctxt "doom hacx.hacx1"
msgid "QUITMSG1"
msgstr "Ces bestioles sont trop fortes pour vous ?"

#, fuzzy
msgctxt "doom hacx.hacx1"
msgid "QUITMSG"
msgstr ""
"Êtes-vous sûr de vouloir\n"
"vous déconnecter en pleine action ?"

msgctxt "doom hacx.hacx1"
msgid "QUITMSG2"
msgstr ""
"On essaye de quitter ?\n"
"Et vous prétendez être un hacker ?"

msgctxt "doom hacx.hacx1"
msgid "QUITMSG3"
msgstr "Reviens ici avant que je t'envoie un virus là où ça fait mal !"

msgctxt "doom hacx.hacx1"
msgid "QUITMSG4"
msgstr "Un vrai hacker ne se déconnecte pas dans le feu de l'action."

msgctxt "doom hacx.hacx1"
msgid "QUITMSG5"
msgstr "Allez, on arrive presque à la meilleure partie !"

msgctxt "doom hacx.hacx1"
msgid "QUITMSG6"
msgstr "Abandonne, et le cyberespace est foutu !"

msgctxt "doom hacx.hacx1"
msgid "QUITMSG7"
msgstr "GENIE t'envoie ses salutations, salaud !"

msgctxt "doom hacx.hacx1"
msgid "QUITMSG8"
msgstr "Eh bien. On est pas vraiment un héros, hacker."

msgctxt "doom hacx.hacx1"
msgid "QUITMSG9"
msgstr "Quoi ? Tu préfère retourner dans ta cellule ?"

msgctxt "doom hacx.hacx1"
msgid "QUITMSG10"
msgstr "T'aurais du prendre la pilule bleue."

msgctxt "doom hacx.hacx1"
msgid "QUITMSG11"
msgstr "Le jeu s'appelle pas \"Panique et cours !\""

msgctxt "doom hacx.hacx1"
msgid "QUITMSG12"
msgstr ""
"Oh, pas de problème.\n"
"Le monde peut attendre d'être sauvé, non ?"

msgctxt "doom hacx.hacx1"
msgid "QUITMSG13"
msgstr "Ca doit être temps de faire comme une mauvaise connection !"

msgctxt "doom hacx.hacx1"
msgid "QUITMSG14"
msgstr "Va pas oublier HacX, maintenant !"

