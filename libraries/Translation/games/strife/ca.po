msgid "TXT_SPEAKER_SEWER_GUARD"
msgstr "Guàrdia de la claveguera"

msgid "TXT_SPEAKER_TECHNICIAN"
msgstr "Tècnic"

msgid "TXT_SPEAKER_GUARD"
msgstr "Guàrdia"

msgid "TXT_SPEAKER_PEASANT"
