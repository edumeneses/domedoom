# MAP02: Between governor's mansion and town hall.
msgid "TXT_DLG_SCRIPT02_D13644_ICANT"
msgstr "No puc creure que m'he quedat amb aquest deure. Diuen que alguna cosa dolenta va sortir d'aquesta porta de clavegueram... Ara em quedo aquí fins que torni a pujar!"

msgid "TXT_RPLY0_SCRIPT02_D13644_WHATG"
msgstr "Quina porta?"

msgid "TXT_RYES0_SCRIPT02_D13644_THESE"
msgstr "La porta de desbordament del clavegueram."

# MAP02: Weapons.
msgid "TXT_DLG_SCRIPT02_D15160_HELLO"
msgstr "Hola amic. Què puc aconseguir per a tu?"

msgid "TXT_RPLY0_SCRIPT02_D15160_ELECT"
msgstr "Cargols elèctrics"

msgid "TXT_RYES0_SCRIPT02_D15160_YOUGO"
