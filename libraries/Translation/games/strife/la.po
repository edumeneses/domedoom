# (in good health = enjoy)
msgid "TXT_RYES2_SCRIPT02_D18192_WEARI"
msgstr "Bene valentem induere."

msgid "TXT_RNO2_SCRIPT02_D18192_COMEB"
msgstr "Redi, cum aliquid emere potes, quod eximium habes!"

