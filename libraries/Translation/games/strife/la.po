msgid "TXT_RPLY0_SCRIPT02_D87928_HEYIN"
msgstr "Heus, aurum opus est!"

msgid "TXT_DLG_SCRIPT02_D89444_BLACK"
msgstr "Merula tibi codicem indicavit, huh? Me terrorem occludam. Macil is quis fuga sunt."

msgid "TXT_RPLY0_SCRIPT02_D89444_THANK"
msgstr "Deo gratias."

msgid "TXT_DLG_SCRIPT02_D90960_WALKA"
msgstr "Abi, puer, abi."

# Arion.
