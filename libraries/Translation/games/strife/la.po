msgid "TXT_RPLY0_SCRIPT03_D10612_IWILL"
msgstr "Volo. Quid postea?"

msgid "TXT_DLG_SCRIPT03_D12128_ASING"
msgstr "Unius cristallus decurrit ad potentiam egetis quae Ordinis scuta inpellit. Dissipate illam crystallum, et tu ferrum ingentia foramina in ordinis munimentis feres. Merula te exploratorem ducet qui viam habet, bone fortuna."

msgid "TXT_RPLY0_SCRIPT03_D12128_WELLG"
msgstr "Dabimus hoc."

msgid "TXT_DLG_SCRIPT03_D13644_FIGHT"
msgstr "Pro Fronte et Libertate Certa. Movere manum."

# (Progammer mission)
msgid "TXT_DLG_SCRIPT03_D15160_YOUVE"
