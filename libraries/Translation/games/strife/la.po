msgid "TXT_DLG_SCRIPT02_D74284_ILLGU"
msgstr "Ego 50 aurum spondeam et si sine omni terrore in urbe redieris, multum est possibilitas mereri, multo magis, et hic paululum adiutorem, qui tibi marginem det."

msgid "TXT_RPLY0_SCRIPT02_D74284_THANK"
