msgid "TXT_RPLY0_SCRIPT02_D78832_TELLM"
msgstr "Dic mihi plura."

msgid "TXT_RPLY1_SCRIPT02_D78832_NOTMY"
msgstr "Non me accusas."

msgid "TXT_DLG_SCRIPT02_D80348_IHAVE"
