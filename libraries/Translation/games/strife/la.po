msgid "TXT_RPLY0_SCRIPT02_D103088_THANK"
msgstr "Gratias"

msgid "TXT_DLG_SCRIPT02_D104604_RELEA"
msgstr "Dimitte me, relinque senem solum."

# MAP03: Macil.
msgid "TXT_DLG_SCRIPT03_D0_WELCO"
msgstr "Grata novissima spe micantem. Solummodo liberum arbitrium habemus Ordini obsistere. Mentes scientias acutissimas habemus et corpora valida multa, sed caremus uno reali, uh… Problemsolver, qui nobis dabit extremam necessitatem. Auxilium NOBIS."

msgid "TXT_RPLY0_SCRIPT03_D0_ALLRI"
msgstr "Recte, accipio."

msgid "TXT_RPLY1_SCRIPT03_D0_NOTHA"
msgstr "Non gratias!"

msgid "TXT_DLG_SCRIPT03_D1516_YOUMI"
msgstr "Retractare fortasse velis, cum sis graviter armatis iratis rebellibus circumdatus."

msgid "TXT_RPLY0_SCRIPT03_D1516_ALLRI"
msgstr "Recte, ego in!"

msgid "TXT_RPLY1_SCRIPT03_D1516_NOTHA"
msgstr "Non gratias."

