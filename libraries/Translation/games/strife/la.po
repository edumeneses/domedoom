# MAP01: Beldin.
msgid "TXT_DLG_SCRIPT01_D0_IDONT"
msgstr "Nolo ullam molestiam a me abesse. Satis mihi negotii fuit quam mihi Harris ille nothus fecit. Pecuniam mihi promisit, sed exspecto ut ab Programmatore interrogatus."

# MAP02: Guy next to Norwall Prison.
msgid "TXT_DLG_SCRIPT02_D0_ILLHE"
msgstr "Adiuvabo te si mihi auxilium feras. Quinque aureos nummos et omnia quae scio narrabo."

msgid "TXT_RPLY0_SCRIPT02_D0_HERES"
msgstr "Hic est aurum."

# (This text is only four seconds on screen)
msgid "TXT_RYES0_SCRIPT02_D0_BESTE"
msgstr "Furtive esto cum occideris, terrores non pones."

# (Four seconds)
msgid "TXT_RNO0_SCRIPT02_D0_WELLI"
msgstr "Bene, non dicam tibi quidquam gratis!"

msgid "TXT_DLG_SCRIPT02_D1516_HAVEY"
msgstr "Ecquis possibilitas nactus es aliam 5 aurum in te?"

msgid "TXT_RPLY0_SCRIPT02_D1516_5GOLD"
msgstr "Quinque auri."

# (Four seconds)
msgid "TXT_RYES0_SCRIPT02_D1516_WELLP"
msgstr "Bene, venenum fulmina custodes statim occidere possunt et terrores non excutere."

# (Four seconds)
msgid "TXT_RNO0_SCRIPT02_D1516_NOSIR"
msgstr "Non domine, nihil tibi gratis narrabo!"

msgid "TXT_DLG_SCRIPT02_D3032_YOUVE"
msgstr "Ultimum rumorem de me iam expressisti!"

# MAP02: Irale.
msgid "TXT_DLG_SCRIPT02_D4548_WHATC"
msgstr "Quid possum tibi?"

msgid "TXT_RPLY0_SCRIPT02_D4548_ASSAU"
msgstr "Gun impetum"

msgid "TXT_RYES0_SCRIPT02_D4548_HEREY"
msgstr "Hic tu."

msgid "TXT_RNO0_SCRIPT02_D4548_YOUCA"
msgstr "Quod nunc praestare non potes."

msgid "TXT_RPLY1_SCRIPT02_D4548_CLIPO"
msgstr "Tonde glandibus"

msgid "TXT_RYES1_SCRIPT02_D4548_THANK"
msgstr "Deo gratias."

msgid "TXT_RNO1_SCRIPT02_D4548_COMEO"
msgstr "Agedum, 10 aurum."

msgid "TXT_RPLY2_SCRIPT02_D4548_AMMOB"
msgstr "Ammo arca"

msgid "TXT_RYES2_SCRIPT02_D4548_HERES"
msgstr "Hic est animus tuus."

msgid "TXT_RNO2_SCRIPT02_D4548_MAYBE"
msgstr "Aliquam interdum tempus aliquam."

# (After destroying the crystal in the Power Station)
msgid "TXT_DLG_SCRIPT02_D6064_GOODN"
msgstr "Evangelium a Fronte ob mutatio. Macil pro mercede et disciplina misit te. Praecepit mihi ut darem tibi."

msgid "TXT_RPLY0_SCRIPT02_D6064_THANK"
msgstr "Deo gratias."

msgid "TXT_RYES0_SCRIPT02_D6064_GLADT"
msgstr "Libenter inservire."

msgid "TXT_DLG_SCRIPT02_D7580_ALLRI"
msgstr "Recte, hic pauca quae agenda monstrant: Peregrinus ne sis: incendium breve erumpit ab impetu sclopetorum in clypeo."

msgid "TXT_RPLY0_SCRIPT02_D7580_ISTHA"
msgstr "Hoccine est?"

msgid "TXT_RYES0_SCRIPT02_D7580_LOOKY"
msgstr "En plura scies postea."

msgid "TXT_DLG_SCRIPT02_D9096_ITHIN"
msgstr "Puto me flammeum unum e crucesignatorum usui humano converti posse. Oh, quid aliud possum te accipere?"

msgid "TXT_RPLY0_SCRIPT02_D9096_FLAME"
msgstr "Flammae iaculator."

msgid "TXT_RYES0_SCRIPT02_D9096_IKNEW"
msgstr "Sciebam quod laboras! Hic tu eam pro spinis sume!"

msgid "TXT_RNO0_SCRIPT02_D9096_LISTE"
msgstr "Audi, nihil possum facere sine partibus rectis!"

msgid "TXT_RPLY1_SCRIPT02_D9096_ASSAU"
msgstr "Gun impetum"

msgid "TXT_RYES1_SCRIPT02_D9096_WELLH"
msgstr "Hem, hic pergis domine!"

msgid "TXT_RNO1_SCRIPT02_D9096_OBVIO"
msgstr "Patet, quod nunc praestare non potes."

msgid "TXT_RPLY2_SCRIPT02_D9096_CLIPO"
msgstr "Tonde glandibus"

msgid "TXT_RYES2_SCRIPT02_D9096_THANK"
msgstr "Deo gratias."

msgid "TXT_RNO2_SCRIPT02_D9096_COMEO"
msgstr "Agedum, 10 aurum."

msgid "TXT_RPLY3_SCRIPT02_D9096_AMMOB"
msgstr "Ammo arca"

msgid "TXT_RYES3_SCRIPT02_D9096_HERES"
msgstr "Hic est animus tuus."

msgid "TXT_RNO3_SCRIPT02_D9096_MAYBE"
msgstr "Aliquam interdum tempus aliquam. vale!"

# (With flamethrower)
msgid "TXT_DLG_SCRIPT02_D10612_NOWTH"
msgstr "Iam quod habes flammatorem, numquid aliud possum te accipere?"

