# MAP04: Green guard.
msgid "TXT_DLG_SCRIPT04_D13644_GETBA"
msgstr "Redi ad opus, nunc!"

msgid "TXT_DLG_SCRIPT04_D15160_GETBA"
msgstr "Redi ad opus, nunc!"

# MAP04: Warehouse → Northeast (worker in red)
msgid "TXT_DLG_SCRIPT04_D16676_WEVEB"
msgstr "Circum horologium per septimanas discurrimus nullo demisso tempore. Dicere vellem Ordinem suppressionem incursionum ante frontem moliri."

# MAP04: Derwin.
msgid "TXT_DLG_SCRIPT04_D18192_OHDAM"
msgstr "Oh, perduint. Praeses te misit. Ibam ei daturus sum excisus, vere essem. Bene, Audi. Fasciculum habeo stashed. Tuum est si aliter spectes."

msgid "TXT_RPLY0_SCRIPT04_D18192_ALLRI"
msgstr "Recte, ego te dimittam."

msgid "TXT_RPLY1_SCRIPT04_D18192_SORRY"
msgstr "Ignoscas, nihil personale."

msgid "TXT_DLG_SCRIPT04_D19708_NUTSI"
msgstr "Nuces si descendo, sic es. Custodes!!"

msgid "TXT_DLG_SCRIPT04_D21224_BUSIN"
msgstr "Negotium meum asinum. Auxilium, servat, vivo vivo."

# MAP04: Worner.
msgid "TXT_DLG_SCRIPT04_D22740_AHIGO"
msgstr "Ah, e Macilo verbum feci ut venires. Iter habeo ad te intra stationem virtutis, sed in periculo est."

msgid "TXT_RPLY0_SCRIPT04_D22740_ILLTA"
