# MAP16: After killing the Bishop
msgid "TXT_SUB_LOG74"
msgstr "Videsne fatum spectrum quod de Episcopi corpore prodiit? Unde id ante vidi?"

msgid "TXT_SUB_LOG75"
msgstr "Judicium vocat tempus. Nunc duas partes assecuti sumus, ut turpia reddere volo. Quid tuus instinctus ad te?"

