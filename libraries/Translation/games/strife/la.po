# (Prison mission)
msgid "TXT_DLG_SCRIPT03_D6064_FRANK"
msgstr "Ingenue se habet pulmentum. Plures missiones peragere debes ad iter praeparandum plures impetus in Ordine. Ultima praeda nostra clades fuit ac plerique capti sunt. Hos captivos liberare peto."

msgid "TXT_RPLY0_SCRIPT03_D6064_ITHIN"
msgstr "Puto me tractare."

msgid "TXT_DLG_SCRIPT03_D7580_TAKET"
msgstr "Cape hanc pecuniam et Irale visita qui arma nostra suppetiae. Tum haec clavis te ad praefectum videndum erit. Ordinis pupula corrupta est, sed agit facere amat. Liberare fratres nostros in armis quodcumque debes."

msgid "TXT_RPLY0_SCRIPT03_D7580_ILLSE"
msgstr "Istuc videro."

msgid "TXT_DLG_SCRIPT03_D9096_FIGHT"
msgstr "Pro Fronte et Libertate Certa. Movere manum."

# (Crystal mission)
msgid "TXT_DLG_SCRIPT03_D10612_THEPR"
