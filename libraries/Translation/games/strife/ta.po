# MAP02: Barkeep.
msgid "TXT_DLG_SCRIPT02_D25772_HELLO"
msgstr "வணக்கம் அந்நியன், நான் உன்னை இதுவரை இங்கு பார்த்ததில்லை. நான் உங்களுக்கு ஒரு இலவச அறிவுரை கூறுகிறேன். நான் நீயாக இருந்தால் கவனமாக இருப்பேன். ஆணை சுதந்திர விருப்பத்தை பொறுத்துக்கொள்ளாது, அவர்களின் அறம் விரைவானது."

msgid "TXT_RPLY0_SCRIPT02_D25772_WHATS"
msgstr "என்ன வார்த்தை?"

# (This text is only four seconds on screen)
msgid "TXT_RYES0_SCRIPT02_D25772_THEWO"
msgstr "வார்த்தை… எலிகள் மற்றும் ரோபோக்களை விட சாக்கடைகள் அதிகம் வைத்திருக்கின்றன."

msgid "TXT_DLG_SCRIPT02_D27288_WHATC"
msgstr "நான் இப்போது உனக்கு என்ன செய்ய முடியும்?"

msgid "TXT_RPLY0_SCRIPT02_D27288_MOREI"
msgstr "மேலும் செய்தி."

# (Four seconds)
msgid "TXT_RYES0_SCRIPT02_D27288_THEGO"
msgstr "நாங்கள் இனி சுதந்திரமானவர்கள் அல்ல என்பதை ஆளுநர் நமக்கு நினைவூட்டுகிறார்."

msgid "TXT_RNO0_SCRIPT02_D27288_COMEB"
msgstr "தங்கம் கிடைத்தவுடன் திரும்பி வா."

msgid "TXT_DLG_SCRIPT02_D28804_WELLY"
msgstr "சரி, இறக்க முயற்சிக்காத ஒருவரிடம் நீங்கள் நிறைய கேள்விகளைக் கேட்கிறீர்கள். நீங்கள் சென்று உங்களைக் கொன்றுவிடாதீர்கள், அல்லது மோசமாக இருக்காதீர்கள் என்பதை உறுதிப்படுத்திக் கொள்ளுங்கள்."

msgid "TXT_RPLY0_SCRIPT02_D28804_MOREI"
msgstr "மேலும் செய்தி."

# (Four seconds)
msgid "TXT_RYES0_SCRIPT02_D28804_THERE"
msgstr "கண்ணை சந்திப்பதை விட ஆர்டரில் இன்னும் நிறைய இருக்கிறது."

msgid "TXT_RNO0_SCRIPT02_D28804_WELLT"
msgstr "தங்கம் கிடைத்தவுடன் பேசுவோம்!"

msgid "TXT_DLG_SCRIPT02_D30320_THATS"
msgstr "அதுதான் நண்பா, அறிவுக் கிணறு வற்றி விட்டது. எவ்வாறாயினும் நான் உங்களிடம் இருக்க வேண்டியதை விட அதிகமாகச் சொல்லிவிட்டேன். நல்ல அதிர்ச்டம்… திரும்பி வராதே."

# MAP02: Power Station guard.
msgid "TXT_DLG_SCRIPT02_D31836_HEYIM"
msgstr "ஏய், நான் எமர்சென்சியின் போது மட்டும் இங்கே இருக்கிறேன். மையத்தை மீறினால், யாரும் உள்ளே வரக்கூடாது... வெளியே வரக்கூடாது."

# MAP02: Rust guards.
msgid "TXT_DLG_SCRIPT02_D33352_WATCH"
msgstr "உன் அடியை கவனி, விவசாயி!"

# MAP02: Gray guards.
msgid "TXT_DLG_SCRIPT02_D34868_WEREG"
msgstr "உன்னைக் கொல்லப் போகிறோம்! "

# MAP02: Green guard.
msgid "TXT_DLG_SCRIPT02_D36384_WHOIN"
msgstr "தீப்பிடித்ததில் நீங்கள் யார்? இந்தப் பகுதியில் யாரும் நடமாடக் கூடாது!"

# MAP02: Golden guards.
msgid "TXT_DLG_SCRIPT02_D37900_YOUTH"
msgstr "நீங்கள் இருக்கிறீர்கள், இங்கு யாருக்கும் இசைவு இல்லை. உடன் செல்லுங்கள்!"

# MAP02: Irale's shop.
msgid "TXT_DLG_SCRIPT02_D39416_IRALE"
msgstr "இரலே உன்னைச் சரியாக அமைக்கும்!"

# MAP02: Harris.
msgid "TXT_DLG_SCRIPT02_D40932_IMKIN"
msgstr "நான் கிளர்ச்சியாளர்களுக்கு ஒரு திறமையான தரகர். உங்களைப் போலவே நல்ல ஒரு பையன் நிறைய தங்கத்தை உருவாக்க முடியும்… நீங்கள் சரியான நபர்களுடன் இணைந்திருந்தால்."

msgid "TXT_RPLY0_SCRIPT02_D40932_IMINT"
msgstr "நான் ஆர்வமாக உள்ளேன்."

msgid "TXT_RPLY1_SCRIPT02_D40932_SCREW"
msgstr "கிளர்ச்சியாளர்களை திருக!"

msgid "TXT_DLG_SCRIPT02_D42448_NONOS"
msgstr "இல்லை, இரண்டாவது வாய்ப்பு இல்லை. காவலர்களே, அவரைக் கொல்லுங்கள்."

msgid "TXT_DLG_SCRIPT02_D43964_GOODC"
msgstr "நல்ல தேர்வு. ஆற்றங்கரையில் உள்ள ஆணையின் சரணாலயம் அவர்களின் அதிகாரப்பூர்வமற்ற சித்திரவதை அறை. உள்ளே ஒரு தங்கக் திருக்குடம் உள்ளது. நீங்கள் அதை ச்வைப் செய்து உங்கள் வெகுமதியைப் பெறுவீர்கள்."

msgid "TXT_RPLY0_SCRIPT02_D43964_HOWAM"
msgstr "நான் அதை எப்படி செய்ய வேண்டும்?"

msgid "TXT_DLG_SCRIPT02_D45480_HERES"
msgstr "இங்கே ஒரு குறுக்கு வில் உள்ளது, நேராக குறிவைத்து --ச்பிளாட்--. நினைவில் வைத்து கொள்ளுங்கள், ஆடம்பரமான கோப்பையைப் பிடித்து, உணவகத்திற்குச் செல்லுங்கள்."

msgid "TXT_RPLY0_SCRIPT02_D45480_COOLI"
msgstr "குளிர். நான் பெற்றுக் கொள்கிறேன்."

msgid "TXT_DLG_SCRIPT02_D46996_WHATA"
msgstr "நீங்கள் எதற்காக காத்திருக்கிறீர்கள்? அந்த கிண்ணத்தை என்னிடம் கொண்டு வா."

msgid "TXT_DLG_SCRIPT02_D48512_HEYIK"
msgstr "ஏய், எனக்குத் தெரியும், இது ஒரு செட்-அப் போல் தெரிகிறது. இவ்வளவு பெரிய கொலை இயந்திரத்தை நான் ஒருபோதும் செய்ய மாட்டேன். பொருள் கிடைத்ததா? அருமை! இப்போது தயாராகுங்கள், நான் உறுதியளித்ததைப் போலவே பொன்னும் பெருமையும். இந்த சாவியை எடுத்துக் கொள்ளுங்கள், கவர்னர் உங்களுக்கு வெகுமதி அளிப்பார்."

msgid "TXT_RPLY0_SCRIPT02_D48512_HEDBE"
msgstr "அவர் நன்றாக இருப்பார். உன் பொருட்டு!"

msgid "TXT_RPLY1_SCRIPT02_D48512_WHATW"
msgstr "என்ன! என் பணம் எங்கே?"

msgid "TXT_DLG_SCRIPT02_D50028_GETLO"
msgstr "தொலைந்து போ, நீ என்னை தொந்தரவு செய்கிறாய்."

msgid "TXT_DLG_SCRIPT02_D51544_NOSEC"
msgstr "இரண்டாவது வாய்ப்பு இல்லை. காவலர்களே, அவரைக் கொல்லுங்கள்."

# MAP02: Mourel.
msgid "TXT_DLG_SCRIPT02_D53060_FIRST"
msgstr "முதலில் ஆயிரக் கணக்கானவர்களைக் கொன்று குவித்தார்கள், இப்போது அவர்கள் அனைத்துத் திறனுள்ள விவசாயிகளையும் குறிப்பிடப்படாத 'சோதனைகளுக்கு' விரும்புகிறார்கள். நான் எப்படி அமைதி காக்க வேண்டும் என்று கட்டளை எதிர்பார்க்கிறது? உனக்கு என்ன வேணும்?"

msgid "TXT_RPLY0_SCRIPT02_D53060_APRIS"
msgstr "ஒரு செயில் பாச், சமாளிப்போம்."

msgid "TXT_DLG_SCRIPT02_D54576_ILIKE"
msgstr "எனக்கு உன்னை ஏற்கனவே பிடிக்கும். நான் செய்ய விரும்பாத இரண்டு வேலைகள் என்னிடம் உள்ளன. ஒன்று குழப்பமானது, மற்றொன்று இரத்தக்களரி."

msgid "TXT_RPLY0_SCRIPT02_D54576_CALLM"
msgstr "என்னை துப்புரவாளர் என்று அழைக்கவும்"

msgid "TXT_RPLY1_SCRIPT02_D54576_IMNOT"
msgstr "நான் கசக்கவில்லை"

# ("messy" chore)
msgid "TXT_DLG_SCRIPT02_D56092_ONEOF"
msgstr "என் கூட்டாளிகளில் ஒருவர் எங்காவது மின்கம்பத்தில் தட்டி மின்சாரத்தை திருடுகிறார். அதைக் கண்டுபிடித்து, அவனுடைய சப்ளையை துண்டிக்கவும், உனக்கு வேண்டியதை நான் தருகிறேன். டோக்கனாக ஏதாவது கொண்டு வா."

# (〃)
msgid "TXT_RPLY0_SCRIPT02_D56092_WHERE"
msgstr "இந்தத் தட்டலை நான் எங்கே கண்டுபிடிப்பது?"

# (〃)
msgid "TXT_DLG_SCRIPT02_D57608_IFIKN"
msgstr "எனக்குத் தெரிந்திருந்தால், இப்போது அது ஒரு வேலையாக இருக்காது அல்லவா? உங்கள் அழகைப் பயன்படுத்துங்கள், ஆனால் அவரது விநியோகத்தை நிறுத்துங்கள்."

# ("bloody" chore)
msgid "TXT_DLG_SCRIPT02_D59124_TELLY"
msgstr "உங்களுக்கு என்ன சொல்லுங்கள், டெர்வின் என்ற பொய்யான சாக்குப்பையில் குழந்தைகளை ஆர்டருக்கு விற்கிறார். அந்த மாதிரியான அவலத்தை நான் பொறுத்துக்கொள்ள மாட்டேன். என் வெட்டு இல்லாமல் இல்லை. டெர்வின் கிடங்கில் வேலை செய்கிறார். அவனைக் கொன்று அவனுடைய காதை என்னிடம் கொண்டு வா, நான் என்ன செய்ய முடியும் என்று பார்க்கிறேன்."

# (〃)
msgid "TXT_RPLY0_SCRIPT02_D59124_HOWDO"
msgstr "நான் எப்படி உள்ளே செல்வது?"

# (〃)
msgid "TXT_DLG_SCRIPT02_D60640_THISK"
msgstr "இந்த விசை உங்களை மின் நிலையத்திற்குள் கொண்டு செல்லும். இரண்டாவது சிந்தனையில், காதை அறுத்து, பின்னர் அவரைக் கொல்லுங்கள். மிகவும் சிறந்தது."

# (after completing "messy" chore)
msgid "TXT_DLG_SCRIPT02_D62156_OHIJU"
msgstr "ஓ, நான் நினைவு பரிசுகளை விரும்புகிறேன். இதோ, இது உங்களை சிறையில் அடைக்கும். வார்டன் மாண்டேக்கிடம் பேசுங்கள். அதன் பிறகு நீங்கள் என்ன செய்தாலும், நான் அதை அறிய விரும்பவில்லை."

# (〃)
msgid "TXT_RPLY0_SCRIPT02_D62156_THANK"
msgstr "நன்றி."

msgid "TXT_DLG_SCRIPT02_D63672_GIVEY"
msgstr "உங்களுக்கு ஒரு குறிப்பு கொடுங்கள். நான் உன்னிடம் பேசுவதை நிறுத்தியதும் நீ கிளம்பு."

# (after completing "bloody" chore)
msgid "TXT_DLG_SCRIPT02_D65188_DOYOU"
msgstr "என்னிடம் நல்ல செய்தி இருக்கிறதா? நான் எல்லாம் காதுகள்."

# (〃)
msgid "TXT_RPLY0_SCRIPT02_D65188_THEDE"
msgstr "செயல் முடிந்தது!"

# (〃)
msgid "TXT_DLG_SCRIPT02_D66704_OHIJU"
msgstr "ஓ, நான் நினைவு பரிசுகளை விரும்புகிறேன். இதோ, இது உங்களை சிறையில் அடைக்கும். வார்டன் மாண்டேக்கிடம் பேசுங்கள். அதன் பிறகு நீங்கள் என்ன செய்தாலும், நான் அதை அறிய விரும்பவில்லை."

# (〃)
msgid "TXT_RPLY0_SCRIPT02_D66704_FINEB"
msgstr "என்னால் நன்றாக இருக்கிறது."

msgid "TXT_DLG_SCRIPT02_D68220_SOYOU"
msgstr "அப்படியென்றால், கலசத்தைத் திருடிய முட்டாள் நீயா? நான் உன்னை ஒரு கிளர்ச்சி திருடன் என்று கைது செய்யப் போகிறேன்… இதன் மூலம் என் பதவியை ஆணை மூலம் மேம்படுத்துகிறேன். அறியாத சிப்பாயாக இருப்பது எப்படி? நான் உங்களுக்கு ஒரு குறிப்பு தருகிறேன், அது வலிக்கும்."

msgid "TXT_RPLY0_SCRIPT02_D68220_ITSUC"
msgstr "அசிங்கமானது!"

msgid "TXT_RYES0_SCRIPT02_D68220_FORYO"
msgstr "உங்களுக்கு அது செய்கிறது."

msgid "TXT_RPLY1_SCRIPT02_D68220_HARRI"
msgstr "ஆரிச் எனக்கு பணம் தருவதாக உறுதியளித்தார்!"

msgid "TXT_RYES1_SCRIPT02_D68220_TOOBA"
msgstr "மிகவும் மோசமானது. நீங்கள் பெறுவது இறப்பு மட்டுமே!"

# MAP02: Rowan.
msgid "TXT_DLG_SCRIPT02_D69736_INASM"
msgstr "ஒரு சிறிய உலகில், சொல் வேகமாக பயணிக்கிறது. உங்கள் பாதையில் இருந்து சில தடைகளை நீக்கிவிட்டீர்கள் என்று கேள்விப்பட்டேன். நல்ல வேலை. நீங்கள் இன்னும் சில இலாபகரமான திட்டங்களில் ஆர்வமாக உள்ளீர்களா?"

msgid "TXT_RPLY0_SCRIPT02_D69736_SUREW"
msgstr "நிச்சயமாக, ஏன் இல்லை."

msgid "TXT_RPLY1_SCRIPT02_D69736_NOTHA"
msgstr "இல்லை நன்றி."

msgid "TXT_RYES1_SCRIPT02_D69736_THENG"
msgstr "பின்னர் தொலைந்து போ!"

# Rowan.
msgid "TXT_DLG_SCRIPT02_D71252_FOOLG"
msgstr "முட்டாள்! காவலர்களே, இந்த இடையூறு செய்யும் பியூனிலிருந்து என்னை விடுவிக்கவும்."

msgid "TXT_DLG_SCRIPT02_D72768_GOODS"
msgstr "நல்லது. சில ஓ, என்னுடைய நண்பர்கள் யாராவது அமைதியாக இருக்க வேண்டும். பெல்டின் அவர்களின் சரணாலயத்தில் ஆணை நடத்தப்படுகிறது. ஆற்றில் இருந்து ஒரு சிறிய கப்பல் மூலம் அரிதாகப் பயன்படுத்தப்படும் நுழைவாயில் உள்ளது, அது பாதுகாப்பற்றது. உள்ளே நுழைந்து, அவனை வாயை மூடிக்கொண்டு, அவனுடைய மோதிரத்தை ஆதாரமாக என்னிடம் கொண்டு வா."

msgid "TXT_RPLY0_SCRIPT02_D72768_WILLI"
msgstr "முயற்சிக்கு மதிப்பு கிடைக்குமா?"

msgid "TXT_DLG_SCRIPT02_D74284_ILLGU"
msgstr "50 தங்கத்திற்கு நான் பொறுப்பு தருகிறேன், நீங்கள் ஊரில் உள்ள ஒவ்வொரு அலாரத்தையும் அமைக்காமல் திரும்பினால், நிறைய சம்பாதிக்க வாய்ப்பு உள்ளது, மேலும் இதோ ஒரு சிறிய உதவியாளர்."

msgid "TXT_RPLY0_SCRIPT02_D74284_THANK"
msgstr "நன்றி, எனக்கு இது தேவைப்படும்."

msgid "TXT_DLG_SCRIPT02_D75800_GOODR"
msgstr "நல்லது. நினைவில் கொள்ளுங்கள், அவரது பேசாமை பொன்னானது."

msgid "TXT_RPLY0_SCRIPT02_D75800_ILLGE"
msgstr "நான் அவனைப் பெற்றுக் கொள்கிறேன்."

msgid "TXT_DLG_SCRIPT02_D77316_MISSI"
msgstr "பணி நிறைவேற்றப்பட்டதா? உங்களிடம் துரோகியின் மோதிரம் இருக்கிறதா?"

msgid "TXT_RPLY0_SCRIPT02_D77316_HESDE"
msgstr "அவர் இறந்துவிட்டார், என் பணம் எங்கே?"

msgid "TXT_RNO0_SCRIPT02_D77316_LIARG"
msgstr "பொய்யர்! போய் மோதிரத்தை எடு!"

msgid "TXT_DLG_SCRIPT02_D78832_HEREY"
msgstr "இதோ, நீங்கள் சம்பாதித்தீர்கள். நீங்கள் கொன்ற துரோகி முன்னணியின் இருப்பிடத்தை வெளிப்படுத்தவிருந்தார். உயிர்களைக் காப்பாற்றினாய். அதிக தங்கத்தையும், கொடுங்கோன்மை இல்லாத எதிர்காலத்தையும் எப்படி சம்பாதிக்க விரும்புகிறீர்கள்?"

msgid "TXT_RPLY0_SCRIPT02_D78832_TELLM"
msgstr "இன்னும் சொல்லுங்க."

msgid "TXT_RPLY1_SCRIPT02_D78832_NOTMY"
msgstr "என் பாணி அல்ல."

msgid "TXT_DLG_SCRIPT02_D80348_IHAVE"
msgstr "முன்னணியின் தலைவரான மாசிலுடன் எனக்கு வர்த்தக உறவு உள்ளது. அவருக்கு உங்களைப் போன்ற ஒரு தீவிரமான நபர் தேவை என்று எனக்குத் தெரியும், அவர் நன்றாகச் செலுத்துகிறார். இந்த மீட்டெடுக்கப்பட்ட காம் யூனிட்டை எடுத்துக் கொள்ளுங்கள், உங்களுக்கு வாய்ப்புகள் கிடைக்கும்."

msgid "TXT_RPLY0_SCRIPT02_D80348_THANK"
msgstr "நன்றி."

msgid "TXT_DLG_SCRIPT02_D81864_GETGO"
msgstr "செல்லுங்கள். நீங்கள் இங்கே சுற்றிக்கொண்டிருந்தால், நாங்கள் இருவரும் இறந்துவிட்டோம்."

msgid "TXT_DLG_SCRIPT02_D83380_APITY"
msgstr "ஒரு பரிதாபம், ஆனால் இப்போது என் நண்பர்களைப் பற்றி உனக்குத் தெரியும், நான் உன்னைக் கொல்ல வேண்டும். காவலர்களே, இந்தக் குப்பையை வெளியே எடுங்கள்!"

msgid "TXT_DLG_SCRIPT02_D84896_FOOLG"
msgstr "முட்டாள். காவலர்களே! தலையிடும் பியூனிலிருந்து என்னை விடுவிக்கவும்."

# Geoff.
msgid "TXT_DLG_SCRIPT02_D86412_WALKA"
msgstr "விலகிச் செல்லுங்கள், பையன், விலகிச் செல்லுங்கள்."

msgid "TXT_DLG_SCRIPT02_D87928_WHATA"
msgstr "நீங்கள் இங்கே என்ன செய்கிறீர்கள்?"

msgid "TXT_RPLY0_SCRIPT02_D87928_HEYIN"
msgstr "ஏய், எனக்கு தங்கம் வேண்டும்!"

msgid "TXT_DLG_SCRIPT02_D89444_BLACK"
msgstr "பிளாக்பேர்ட் உங்களுக்கு குறியீட்டைச் சொன்னது, இல்லையா? அலாரத்தை அணைக்கிறேன். Macil ஒரு வானூர்தி கீழே உள்ளது."

msgid "TXT_RPLY0_SCRIPT02_D89444_THANK"
msgstr "நன்றி."

msgid "TXT_DLG_SCRIPT02_D90960_WALKA"
msgstr "விலகிச் செல்லுங்கள், பையன், விலகிச் செல்லுங்கள்."

# Arion.
msgid "TXT_DLG_SCRIPT02_D92476_DOYOU"
msgstr "கவர்னருடன் சந்திப்பு இருக்கிறதா? "

msgid "TXT_RPLY0_SCRIPT02_D92476_OFCOU"
msgstr "நிச்சயமாக!"

msgid "TXT_RPLY1_SCRIPT02_D92476_NOAND"
msgstr "இல்லை, எனக்கு ஒன்று தேவையில்லை!"

msgid "TXT_DLG_SCRIPT02_D93992_SORRY"
msgstr "மன்னிக்கவும்! நான் சொல்லவில்லை... தயவுசெய்து மேலே செல்லுங்கள்."

msgid "TXT_RPLY0_SCRIPT02_D93992_IKNEW"
msgstr "நீங்கள் அப்படிச் சொல்வீர்கள் என்று எனக்குத் தெரியும்."

msgid "TXT_DLG_SCRIPT02_D95508_IFYOU"
msgstr "உங்களுக்கு இவ்வளவு விரைவு என்றால் என்னுடன் நேரத்தை வீணாக்காதீர்கள்."

# MAP02: MacGuffin
msgid "TXT_DLG_SCRIPT02_D97024_RELEA"
msgstr "என்னை விடுவிக்கவும், ஒரு முதியவரை தனியாக விடுங்கள்."

# (after accepting "messy" chore)
msgid "TXT_DLG_SCRIPT02_D98540_YOUSE"
msgstr "நீ ஞானத்தைத் தேடுகிறாயா மகனே? ‘ஏன்?’ என்ற ஒரே ஒரு கேள்வியை மட்டும் கேட்கும்படி கட்டளை பார்த்திருக்கிறது."

msgid "TXT_RPLY0_SCRIPT02_D98540_WHERE"
msgstr "மின் இணைப்பு எங்கே?"

msgid "TXT_RPLY1_SCRIPT02_D98540_WHERE"
msgstr "ஆர்டரின் முக்கிய இடம் எங்கே?"

msgid "TXT_RPLY2_SCRIPT02_D98540_WHERE"
msgstr "சட்டவிரோத குழாய் எங்கே?"

msgid "TXT_DLG_SCRIPT02_D100056_ILLTE"
msgstr "அது எங்கே என்று நான் உங்களுக்குச் சொல்கிறேன், ஆனால் நீங்கள் யாருடைய இணைப்பைச் சிதைப்பீர்கள் என்று எனக்குத் தெரியவில்லை. இங்கேயே கழிவுநீர் ஆலையில் உள்ளது."

msgid "TXT_RPLY0_SCRIPT02_D100056_THANK"
msgstr "நன்றி"

msgid "TXT_DLG_SCRIPT02_D101572_THATS"
msgstr "இங்கேயே கழிவுநீர் ஆலையில் உள்ளது. ஆனால் இது முன்னணியின் இணைப்பு. ஆர்டர் என்று யார் சொன்னாலும் அது தவறு."

msgid "TXT_RPLY0_SCRIPT02_D101572_THANK"
msgstr "நன்றி"

msgid "TXT_DLG_SCRIPT02_D103088_IFYOU"
msgstr "இது சட்டவிரோதமானது என்று நீங்கள் கூறினால், நான் உங்களை ஒன்றும் செய்ய விரும்பவில்லை. எனக்கு போதுமான தொல்லை உள்ளது."

msgid "TXT_RPLY0_SCRIPT02_D103088_THANK"
msgstr "நன்றி"

msgid "TXT_DLG_SCRIPT02_D104604_RELEA"
msgstr "என்னை விடுவிக்கவும், ஒரு முதியவரை தனியாக விடுங்கள்."

# MAP03: Macil.
msgid "TXT_DLG_SCRIPT03_D0_WELCO"
msgstr "நம்பிக்கையின் கடைசி மின்னலுக்கு வரவேற்கிறோம். உத்தரவை எதிர்க்கும் விடுதலை எங்களுக்கு மட்டுமே உள்ளது. எங்களிடம் கூர்மையான அறிவியல் மனங்களும், பல திறமையான உடல்களும் உள்ளன, ஆனால் நம்மிடம் உண்மையான ஒன்று இல்லை, ஐயோ... பிரச்சனைத் தீர்ப்பவர், நமக்குத் தேவையானதை யார் தருவார்கள். எங்களுக்கு உதவுங்கள்."

msgid "TXT_RPLY0_SCRIPT03_D0_ALLRI"
msgstr "சரி, நான் ஏற்றுக்கொள்கிறேன்."

msgid "TXT_RPLY1_SCRIPT03_D0_NOTHA"
msgstr "இல்லை நன்றி!"

msgid "TXT_DLG_SCRIPT03_D1516_YOUMI"
msgstr "நீங்கள் கருவி ஏந்திய கோபமான கிளர்ச்சியாளர்களால் சூழப்பட்டிருப்பதைக் கண்டு நீங்கள் மறுபரிசீலனை செய்ய விரும்பலாம்."

msgid "TXT_RPLY0_SCRIPT03_D1516_ALLRI"
msgstr "சரி, நான் உள்ளே இருக்கிறேன்!"

msgid "TXT_RPLY1_SCRIPT03_D1516_NOTHA"
msgstr "இல்லை நன்றி."

msgid "TXT_DLG_SCRIPT03_D3032_THEND"
msgstr "பின்னர் அவமானத்திலும் அவமானத்திலும் இறந்துவிடுவார்கள்."

msgid "TXT_DLG_SCRIPT03_D4548_GOODB"
msgstr "நல்லது, பிளாக்பேர்ட் தொடர்ந்து உங்கள் வழிகாட்டியாக இருக்கும். அவள் உங்களுக்கு மிகவும் பிரகாசமாக இருந்தாள். நீங்கள் ஒன்றாக ஆணை மற்றும் அவர்களின் மனிதாபிமானமற்ற ஊழியர்களின் இரகசியங்களை திறக்க வேண்டும். உள்ளே சென்று அவர்களை கீழே இறக்கவும்."

msgid "TXT_RPLY0_SCRIPT03_D4548_WHERE"
msgstr "நான் எங்கு தொடங்குவது?"

# (Prison mission)
msgid "TXT_DLG_SCRIPT03_D6064_FRANK"
msgstr "வெளிப்படையாகச் சொன்னால், நிலைமை குழப்பமாக இருக்கிறது. ஆர்டரின் மீது அதிக தாக்குதல்களுக்கு வழியைத் தயாரிக்க நீங்கள் பல பணிகளைச் செய்ய வேண்டும். எங்கள் கடைசி தாக்குதல் ஒரு பேரழிவு மற்றும் எங்கள் துருப்புக்களில் பெரும்பாலோர் கைப்பற்றப்பட்டனர். இந்தக் கைதிகளை நீங்கள் விடுவிக்க வேண்டும்."

msgid "TXT_RPLY0_SCRIPT03_D6064_ITHIN"
msgstr "என்னால் சமாளிக்க முடியும் என்று நினைக்கிறேன்."

msgid "TXT_DLG_SCRIPT03_D7580_TAKET"
msgstr "இந்தப் பணத்தை எடுத்துக்கொண்டு எங்கள் ஆயுதங்களை சப்ளை செய்யும் ஈரேலைப் பார்க்கவும். பின்னர், இந்த திறவுகோல் கவர்னரைப் பார்க்க உங்களை அழைத்துச் செல்லும். அவர் ஒழுங்கின் ஊழல் கைப்பாவை, ஆனால் அவர் ஒப்பந்தங்களைச் செய்ய விரும்புகிறார். எங்கள் சகோதரர்களை விடுவிக்க உங்களுக்கு தேவையான அனைத்தையும் செய்யுங்கள்."

msgid "TXT_RPLY0_SCRIPT03_D7580_ILLSE"
msgstr "நான் பார்த்துக் கொள்கிறேன்."

msgid "TXT_DLG_SCRIPT03_D9096_FIGHT"
msgstr "முன்னணி மற்றும் சுதந்திரத்திற்காக போராடுங்கள். வெளியே செல்லவும்."

# (Crystal mission)
msgid "TXT_DLG_SCRIPT03_D10612_THEPR"
msgstr "கைதிகள் மீண்டும் வரவேற்கப்பட்டனர், உங்களுக்கு நன்றி. இதோ கொஞ்சம் தங்கம், மருத்துவம் மற்றும் ஆயுதப் பயிற்சியாளரிடம் சென்று வாருங்கள், பிறகு, உங்களுக்காக எனக்கு அதிக இலக்குகள் உள்ளன."

msgid "TXT_RPLY0_SCRIPT03_D10612_IWILL"
msgstr "நான் செய்வேன். அடுத்து என்ன?"

msgid "TXT_DLG_SCRIPT03_D12128_ASING"
msgstr "ஒரு படிகமானது ஆர்டரின் கவசங்களை இயக்கும் மின் கட்டத்தை இயக்குகிறது. அந்த படிகத்தை அழிக்கவும், நீங்கள் ஆர்டரின் பாதுகாப்பில் பெரிய துளைகளை குத்துவீர்கள். பிளாக்பேர்ட் உங்களை ஒரு உளவாளிக்கு அழைத்துச் செல்லும், அவருக்கு நல்ல அதிர்ச்டம்."

msgid "TXT_RPLY0_SCRIPT03_D12128_WELLG"
msgstr "நாங்கள் அதைப் பெறுவோம்."

msgid "TXT_DLG_SCRIPT03_D13644_FIGHT"
msgstr "முன்னணி மற்றும் சுதந்திரத்திற்காக போராடுங்கள். வெளியே செல்லவும்."

# (Progammer mission)
msgid "TXT_DLG_SCRIPT03_D15160_YOUVE"
msgstr "எங்கள் எதிர்பார்ப்புகளை எல்லாம் தாண்டிவிட்டீர்கள். உங்கள் துணிச்சலால் எங்கள் படைகள் நகர்ந்து கொண்டிருக்கின்றன. ஒரு குறிப்பிட்ட இலக்குடன் நீங்கள் இருவரும் தாக்குதலில் சேர வேண்டும் என்று நான் விரும்புகிறேன். புரோகிராமரை வெளியே எடு. ஆர்டரின் இந்த அடுக்கைப் பற்றி நாங்கள் கண்டுபிடித்ததை வெளிப்படுத்த வேண்டிய நேரம் இது."

msgid "TXT_RPLY0_SCRIPT03_D15160_TELLM"
msgstr "எங்களுக்குத் தெரிந்ததைச் சொல்லுங்கள்."

msgid "TXT_DLG_SCRIPT03_D16676_THEPR"
msgstr "புரோகிராமர்களின் குகை கோட்டையில் உள்ளது. இப்போது, மருத்துவரைப் பார்த்து, கொஞ்சம் வெடிமருந்துகளை எடுத்துக்கொண்டு போய் அவரைக் கொண்டு வாருங்கள்."

msgid "TXT_RPLY0_SCRIPT03_D16676_LETME"
msgstr "என்னை அங்கே அனுமதியுங்கள்!"

msgid "TXT_DLG_SCRIPT03_D18192_FIGHT"
msgstr "முன்னணி மற்றும் சுதந்திரத்திற்காக போராடுங்கள். வெளியே செல்லவும்."

# MAP03: Barracks.
msgid "TXT_DLG_SCRIPT03_D19708_REMEM"
msgstr "டவுன்ஆல் எப்படி இருந்தது என்பதை நினைவில் கொள்க? அவர்கள் எங்களிடம் என்ன செய்யத் தயாராக இருக்கிறார்கள் என்பதற்கான மென்மையான நினைவூட்டல். கவனமாக இருங்கள்."

# MAP03: Upstairs, corridor.
msgid "TXT_DLG_SCRIPT03_D21224_TALKT"
msgstr "மாசிலுடன் பேசுங்கள். அவர் உங்களுக்கு உதவ முடியும்."

# MAP03: Barracks.
# (dead meat = corpse)
msgid "TXT_DLG_SCRIPT03_D22740_IVEHE"
msgstr "இந்த உத்தரவைத் தகர்க்க Macil ஒரு திட்டம் வகுத்திருப்பதாகக் கேள்விப்பட்டேன். நன்றாக இருப்பது நல்லது. இன்னும் ஒரு தோல்வி மற்றும் நாம் அனைவரும் இறந்த இறைச்சி."

msgid "TXT_DLG_SCRIPT03_D24256_AFEWO"
msgstr "இவற்றில் சில பீப்பாய்கள் அவற்றின் நீர் விநியோகத்தில் கொட்டப்படுகின்றன, முரண்பாடுகள் கொஞ்சம் கூட இருக்க வேண்டும்."

msgid "TXT_DLG_SCRIPT03_D25772_SOYOU"
msgstr "அப்படியென்றால் நீங்கள் புதிய செயலாளரா? நன்றி, நீங்கள் இல்லாமல், நாங்கள் அனைவரும் இப்போது இறந்துவிடுவோம்."

# MAP03: Gerald (no implant)
msgid "TXT_DLG_SCRIPT03_D27288_IMWOR"
msgstr "நான் ஏதாவது செய்துகொண்டிருக்கிறேன், அது நமக்கு ஒரு நன்மையைத் தரும். இது உங்கள் சகிப்புத்தன்மையை அதிகரிக்கும் மற்றும் உங்களை முழுமையாக உற்சாகப்படுத்தும். நான் கிட்டத்தட்ட எல்லா பிழைகளையும் தீர்த்துவிட்டேன். நான் உங்களுக்காக ஏதாவது செய்யலாமா?"

msgid "TXT_RPLY0_SCRIPT03_D27288_PATCH"
msgstr "என்னை ஒட்டவும்."

msgid "TXT_RYES0_SCRIPT03_D27288_BOYYO"
msgstr "பையன், நீங்கள் ஒரு உண்மையான குழப்பம். நான் என்ன செய்ய முடியும் என்று பார்க்கிறேன்."

msgid "TXT_RPLY1_SCRIPT03_D27288_STAMI"
msgstr "ச்டாமினா உள்வைப்பு?"

msgid "TXT_RYES1_SCRIPT03_D27288_ALLRI"
msgstr "சரி, இதற்கு சிறிது நேரம் ஆகாது."

msgid "TXT_RNO1_SCRIPT03_D27288_ITSNO"
msgstr "அது இன்னும் முடியவில்லை."

# (one upgrade)
msgid "TXT_DLG_SCRIPT03_D28804_HEYIM"
msgstr "ஏய், நான் உங்கள் உள்வைப்பின் புதுப்பிக்கப்பட்ட பதிப்பில் வேலை செய்து வருகிறேன். என்னால் வேறு ஏதாவது செய்ய முடியுமா?"

msgid "TXT_RPLY0_SCRIPT03_D28804_PATCH"
msgstr "என்னை ஒட்டவும்."

msgid "TXT_RYES0_SCRIPT03_D28804_WELLA"
msgstr "குறைந்தபட்சம் உங்கள் செயலையாவது பார்க்கிறீர்கள்."

msgid "TXT_RPLY1_SCRIPT03_D28804_IMPLA"
msgstr "உள்வைப்பு மேம்படுத்தவா?"

msgid "TXT_RYES1_SCRIPT03_D28804_GOODT"
msgstr "நல்ல சேதி, மிகவும் பாதுகாப்பாக இருக்க முடியாது."

msgid "TXT_RNO1_SCRIPT03_D28804_IMALM"
msgstr "நான் கிட்டத்தட்ட முடித்துவிட்டேன், ஆனால் முழுமையாக இல்லை."

# (two upgrades)
msgid "TXT_DLG_SCRIPT03_D30320_ALLRI"
msgstr "சரி, கிட்டத்தட்ட எல்லாவற்றையும் சரியாகச் செய்துவிட்டேன். விடுபட சில பிரச்சனைகள் மீதம் இருந்தன. உங்களுக்கு வேறு ஏதாவது தேவையா? "

msgid "TXT_RPLY0_SCRIPT03_D30320_PATCH"
msgstr "என்னை ஒட்டவும்."

msgid "TXT_RYES0_SCRIPT03_D30320_WHATH"
msgstr "நீங்கள் என்ன செய்ய முயற்சித்தீர்கள்? ஒரு சிலுவைப்போருடன் நேருக்கு நேர் செல்லவா?"

msgid "TXT_RPLY1_SCRIPT03_D30320_IMPLA"
msgstr "உள்வைப்பு மேம்படுத்தல்?."

msgid "TXT_RYES1_SCRIPT03_D30320_THATS"
msgstr "அது உங்களுக்காக செய்ய வேண்டும்."

msgid "TXT_RNO1_SCRIPT03_D30320_LETME"
msgstr "முதலில் இன்னும் சில சோதனைகளை நடத்துகிறேன்."

# (?)
msgid "TXT_DLG_SCRIPT03_D31836_THATS"
msgstr "நான் இப்போது உள்வைப்பில் செய்யக்கூடியது அவ்வளவுதான். ஒருவேளை ஏதாவது குணமாகுமா?"

msgid "TXT_RPLY0_SCRIPT03_D31836_YEAH"
msgstr "ஆம்."

msgid "TXT_RYES0_SCRIPT03_D31836_BOYYO"
msgstr "பையன், நீங்கள் ஒரு உண்மையான குழப்பம். நான் என்ன செய்ய முடியும் என்று பார்க்கிறேன்."

# MAP03: Feris (no training).
msgid "TXT_DLG_SCRIPT03_D33352_WHATC"
msgstr "நான் உனக்கு என்ன செய்ய முடியும்?"

msgid "TXT_RPLY0_SCRIPT03_D33352_IMOUT"
msgstr "எனக்கு குண்டுகள் தீர்ந்துவிட்டது."

msgid "TXT_RYES0_SCRIPT03_D33352_HERES"
msgstr "இதோ உங்களுக்காக சில வெடிமருந்துகள். அதை வீணாக்காதீர்கள்."

msgid "TXT_RPLY1_SCRIPT03_D33352_TEACH"
msgstr "எனக்கு கற்றுக்கொடுங்கள்."

msgid "TXT_RYES1_SCRIPT03_D33352_ALLRI"
msgstr "சரி, நான் உங்களுக்கு சில சிறிய குறிப்புகளைக் காட்டுகிறேன்."

msgid "TXT_RNO1_SCRIPT03_D33352_YOURE"
msgstr "நீங்கள் இன்னும் தயாராகவில்லை."

# (one training)
msgid "TXT_DLG_SCRIPT03_D34868_BACKA"
msgstr "மீண்டும்? உனக்கு என்ன வேண்டும்?"

msgid "TXT_RPLY0_SCRIPT03_D34868_IMOUT"
msgstr "எனக்கு குண்டுகள் தீர்ந்துவிட்டது."

msgid "TXT_RYES0_SCRIPT03_D34868_HERES"
msgstr "இதோ உங்களுக்காக சில வெடிமருந்துகள். அதை வீணாக்காதீர்கள்."

msgid "TXT_RNO0_SCRIPT03_D34868_YOUVE"
msgstr "உங்களிடம் போதுமான வெடிமருந்துகள் உள்ளன."

msgid "TXT_RPLY1_SCRIPT03_D34868_TEACH"
msgstr "எனக்கு கற்றுக்கொடுங்கள்."

msgid "TXT_RYES1_SCRIPT03_D34868_ALLRI"
msgstr "சரி, இது உங்களை சிறிது நேரம் வைத்திருக்க வேண்டும்."

msgid "TXT_RNO1_SCRIPT03_D34868_SORRY"
msgstr "மன்னிக்கவும், முடியாது. நான் மாசிலின் உத்தரவுகளை பின்பற்றுகிறேன்."

# (two trainings)
msgid "TXT_DLG_SCRIPT03_D36384_WELLW"
msgstr "அது எது, தோட்டாக்கள் அல்லது பயிற்சி? நாங்கள் கைப்பற்றிய அந்த புதிய ஆயுதங்களில் என் கைகளைப் பெற நான் காத்திருக்க முடியாது. கொஞ்சம் பயிற்சி, பிறகு நிறைய பழிவாங்கல்."

msgid "TXT_RPLY0_SCRIPT03_D36384_IMOUT"
msgstr "நான் வெடிமருந்து தீர்ந்துவிட்டேன்."

msgid "TXT_RYES0_SCRIPT03_D36384_HERES"
msgstr "இதோ உங்களுக்காக சில வெடிமருந்துகள். அதை வீணாக்காதீர்கள்."

msgid "TXT_RNO0_SCRIPT03_D36384_YOUVE"
msgstr "உங்களிடம் போதுமான வெடிமருந்துகள் உள்ளன."

msgid "TXT_RPLY1_SCRIPT03_D36384_TEACH"
msgstr "எனக்கு கற்றுக்கொடுங்கள்."

msgid "TXT_RYES1_SCRIPT03_D36384_OKTAK"
msgstr "ஓ.கே. நீங்கள் இங்கே கற்றுக்கொண்டதை எடுத்து, அந்த ஆணைக் கட்டிகளை நரகத்திற்கு வழி காட்டுங்கள்."

msgid "TXT_RNO1_SCRIPT03_D36384_COMEB"
msgstr "நேரம் ஆகிவிட்டது என்று Macil கூறும்போது, பிறகு வாருங்கள்."

# (three trainings)
msgid "TXT_DLG_SCRIPT03_D37900_IVETA"
msgstr "என்னால் முடிந்த அனைத்தையும் இப்போது உங்களுக்குக் கற்றுக் கொடுத்தேன். புதிய ஆயுதங்களை அவற்றின் வேகத்தில் வைக்க எனக்கு சிறிது நேரம் கொடுங்கள். நீங்கள் தோட்டாக்கள் தீர்ந்துவிட்டால் தவிர."

msgid "TXT_RPLY0_SCRIPT03_D37900_YESIA"
msgstr "ஆம் நான் தான்."

msgid "TXT_RYES0_SCRIPT03_D37900_HEREY"
msgstr "இதோ போ."

# MAP03: Upstairs.
msgid "TXT_DLG_SCRIPT03_D39416_DONTG"
msgstr "ஊரில் மகிழ்ச்சியாக இருக்க வேண்டாம். நீங்கள் அலாரத்தை இயக்குவீர்கள், அவர்கள் கோட்டையிலிருந்து காவலர்களை அனுப்பத் தொடங்குவார்கள். "

# MAP03: Near Macil.
msgid "TXT_DLG_SCRIPT03_D40932_WELCO"
msgstr "வரவேற்கிறோம், நாங்கள் எப்போதும் கூடுதல் உதவியைப் பயன்படுத்தலாம்."

msgid "TXT_DLG_SCRIPT03_D42448_WHENI"
msgstr "நான் இன்னும் நடவடிக்கையில் இருந்தபோது, வலுவூட்டல்கள் வருவதற்கு முன்பு ஒரு உதவியாளரை பரிசோதிக்கும் வாய்ப்பு எங்களுக்கு கிடைத்தது. கேளுங்கள், அவர்கள் மனிதர்கள் அல்ல."

# MAP03: Downstairs.
msgid "TXT_DLG_SCRIPT03_D43964_WERET"
msgstr "கோட்டை வாயில் பொறிமுறைகள் எங்கு உள்ளன என்பதை நாங்கள் கண்டுபிடிக்க முயற்சிக்கிறோம், ஆனால் இதுவரை எங்களுக்கு அதிர்ச்டம் இல்லை."

msgid "TXT_DLG_SCRIPT03_D45480_DONTG"
msgstr "பிடிபடாதே. அவர்கள் சிறையில் அடைக்கப்பட்ட பிறகு நம் மக்களுக்கு என்ன செய்கிறார்கள் என்பது பற்றிய அதிர்ச்சி கதைகளை நான் கேள்விப்பட்டிருக்கிறேன். அவர்கள் ஒரு தடயமும் இல்லாமல் மறைந்து விடுகிறார்கள்."

msgid "TXT_DLG_SCRIPT03_D46996_HERES"
msgstr "ஆர்டரின் டின்சோல்டியர்கள் வேறு திசையில் செல்வதை நீங்கள் எப்போதாவது பார்த்தால், இதோ சில அறிவுரைகள். அவர்கள் வேகமான மற்றும் கொடூரமானவர்கள்."

msgid "TXT_DLG_SCRIPT03_D48512_LEAVE"
msgstr "என்னை இருக்க விடு. நான் மாசிலுக்காக ஏதாவது செய்கிறேன்."

# MAP04: Reactor Core red guard.
msgid "TXT_DLG_SCRIPT04_D0_SORRY"
msgstr "மன்னிக்கவும், இல்லை. உங்களுக்கு இசைவு இல்லை."

msgid "TXT_DLG_SCRIPT04_D1516_STOPS"
msgstr "நிறுத்து! உங்கள் அடையாளம் பேட்சைக் காட்டு."

msgid "TXT_RPLY0_SCRIPT04_D1516_HERES"
msgstr "இதோ எனது ஐ.டி."

msgid "TXT_DLG_SCRIPT04_D3032_OHOKS"
msgstr "ஓ, சரி. நிச்சயமாக மேலே செல்லுங்கள். இனிய நாள்."

# MAP04: Warehouse red guard.
msgid "TXT_DLG_SCRIPT04_D4548_DERWI"
msgstr "டெர்வின்? ஆம், அவர் கிடங்கில் இருக்கிறார், ஆனால் நீங்கள் அழிக்கப்படும் வரை நீங்கள் உள்ளே வரமாட்டீர்கள்."

msgid "TXT_RPLY0_SCRIPT04_D4548_IVEGO"
msgstr "எனக்கு இசைவு கிடைத்துள்ளது."

msgid "TXT_DLG_SCRIPT04_D6064_GOON"
msgstr "தொடருங்கள்."

msgid "TXT_RPLY0_SCRIPT04_D6064_DOYOU"
msgstr "அவர் எங்கே இருக்கிறார் தெரியுமா?"

msgid "TXT_DLG_SCRIPT04_D7580_IDONT"
msgstr "யாரும் எங்கே இருக்கிறார்கள் என்று தெரியவில்லை. நான் எலிப்பொறியை மூடி வைத்திருக்கிறேன்."

msgid "TXT_DLG_SCRIPT04_D9096_YOUAR"
msgstr "நீங்கள் விரும்பத்தகாத கவனச்சிதறல்."

# MAP04: Reactor Core gray guard.
msgid "TXT_DLG_SCRIPT04_D10612_MOVEA"
msgstr "உலோகத்தை எடுத்துச் செல்லவும் அல்லது சுவைக்கவும்."

msgid "TXT_DLG_SCRIPT04_D12128_PASSY"
msgstr "அணுகலுக்கு உங்கள் ஐடியை இங்கே அனுப்பவும்."

# MAP04: Green guard.
msgid "TXT_DLG_SCRIPT04_D13644_GETBA"
msgstr "இப்போது வேலைக்குத் திரும்பு!"

msgid "TXT_DLG_SCRIPT04_D15160_GETBA"
msgstr "இப்போது வேலைக்குத் திரும்பு!"

# MAP04: Warehouse → Northeast (worker in red)
msgid "TXT_DLG_SCRIPT04_D16676_WEVEB"
msgstr "வாரக்கணக்கில் நேரம் இல்லாமல் கடிகாரத்தைச் சுற்றி ஓடிக்கொண்டிருக்கிறோம். முன்னனியில் ஒரு அடக்குமுறை சோதனைக்கு ஆணை திட்டமிடுகிறது என்று நான் கூறுவேன்."

# MAP04: Derwin.
msgid "TXT_DLG_SCRIPT04_D18192_OHDAM"
msgstr "அடடா. கவர்னர் உங்களை அனுப்பினார். நான் அவருக்கு வெட்டப் போகிறேன், உண்மையில் நான்தான். சரி, கேள். நான் ஒரு மூட்டை பதுக்கி வைத்துள்ளேன். நீங்கள் வேறு வழியில் பார்த்தால் அது உங்களுடையது."

msgid "TXT_RPLY0_SCRIPT04_D18192_ALLRI"
msgstr "சரி, நான் உன்னை போக விடுகிறேன்."

msgid "TXT_RPLY1_SCRIPT04_D18192_SORRY"
msgstr "மன்னிக்கவும், தனிப்பட்ட எதுவும் இல்லை."

msgid "TXT_DLG_SCRIPT04_D19708_NUTSI"
msgstr "நட்ச், நான் கீழே போகிறேன் என்றால், நீங்களும் அப்படித்தான். காவலர்களே!!"

msgid "TXT_DLG_SCRIPT04_D21224_BUSIN"
msgstr "வணிகம் என் கழுதை. உதவி, காவலர்களே, எனக்கு நேரலை உள்ளது."

# MAP04: Worner.
msgid "TXT_DLG_SCRIPT04_D22740_AHIGO"
msgstr "ஆ, நீங்கள் வருவீர்கள் என்று மசிலிடமிருந்து எனக்கு செய்தி கிடைத்தது. உங்களை மின் நிலையத்திற்குள் அழைத்துச் செல்ல என்னிடம் ஒரு வழி உள்ளது, ஆனால் அது ஆபத்தான பக்கத்தில் உள்ளது."

msgid "TXT_RPLY0_SCRIPT04_D22740_ILLTA"
msgstr "நான் என் வாய்ப்புகளை எடுத்துக்கொள்கிறேன்."

msgid "TXT_DLG_SCRIPT04_D24256_ALLRI"
msgstr "சரி, நான் ஒரு ஐ.டி. அணுஉலையின் குளிரூட்டும் குழியில் விழுந்த சில முட்டாள்களின் சடலத்திலிருந்து. --blat-- உடனடி ஆழமான வறுக்கவும்."

msgid "TXT_RPLY0_SCRIPT04_D24256_WHATS"
msgstr "உள்ளே நுழைந்தவுடன் நான் என்ன செய்ய வேண்டும்?"

msgid "TXT_DLG_SCRIPT04_D25772_TELLW"
msgstr "மிச்டர் கிரிச்பிக்கு நீங்கள்தான் மாற்றுத் தொழிலாளி என்று யார் கேட்டாலும் சொல்லுங்கள். வேலை செய்யும் அளவுக்கு ஊமையாக இருக்கிறது. ஓ, எங்களுக்கு மேலே இருக்கும் ச்டோர்ரூமை நீங்கள் பார்க்க விரும்பலாம்."

msgid "TXT_RPLY0_SCRIPT04_D25772_BOYIH"
msgstr "பையன் இந்த ஐ.டி. வேலை செய்கிறது."

msgid "TXT_DLG_SCRIPT04_D27288_GETOU"
msgstr "இங்கிருந்து வெளியேறுங்கள், நீங்கள் மிச்டர் டெட் ஆக விரும்பாதவரை."

# MAP04: Warehouse → Dock Worker.
msgid "TXT_DLG_SCRIPT04_D28804_HEYLE"
msgstr "ஏய், என்னை விட்டுவிடு. நேரத்தை வீணடிப்பதாக அவர்கள் பிடித்தால் நாம் இறந்துவிடுவோம், அல்லது கூடுதல் வேலை."

# MAP04: Reactor Core → Northern alarm green door → Level 2 door
msgid "TXT_DLG_SCRIPT04_D30320_SUCHP"
msgstr "இத்தகைய அழுத்தம், இந்த விகிதத்தில் நாம் விரைவில் சாதாரண மாற்றங்களுக்கு திரும்புவோம். நாங்கள் கோட்டைக்கு டன் சக்தியை செலுத்துகிறோம், நான் அந்த புதிய ஆயுதங்களை பதிவு செய்து முடித்துவிட்டேன்."

msgid "TXT_RPLY0_SCRIPT04_D30320_WEAPO"
msgstr "ஆயுதங்களா?"

msgid "TXT_DLG_SCRIPT04_D31836_WHATD"
msgstr "நீங்கள் என்ன நினைக்கிறீர்கள், நாங்கள் சாக்சில் காப்புப் பிரதி எடுத்துள்ளோம்?"

msgid "TXT_RPLY0_SCRIPT04_D31836_WHATK"
msgstr "என்ன வகையான ஆயுதங்கள்?"

msgid "TXT_DLG_SCRIPT04_D33352_AREYO"
msgstr "நீங்கள் காது கேளாதவரா? நான் எவ்வளவு பிசியாக இருக்கிறேன் என்று தான் சொன்னேன். வேலைக்குத் திரும்பு."

# MAP04: Reactor Core → Southern alarm green door
msgid "TXT_DLG_SCRIPT04_D34868_WHOAR"
msgstr "நீங்கள் யார்? இந்த பகுதியில் இசைவு நிலை இரண்டு பணியாளர்கள் மட்டுமே அனுமதிக்கப்படுகிறார்கள்."

msgid "TXT_RPLY0_SCRIPT04_D34868_IMTHE"
msgstr "நான் மாற்றுத் தொழிலாளி."

msgid "TXT_DLG_SCRIPT04_D36384_ABOUT"
msgstr "நீங்கள் வந்த நேரம். கெட்ரிக் உடன் பேசுங்கள். ஓ, இந்த கீ கார்டை எடு. உங்கள் முதல் நாளில் நீங்கள் சுட விரும்பவில்லை, இல்லையா?"

msgid "TXT_RPLY0_SCRIPT04_D36384_WHERE"
msgstr "ஆற்றல் படிகம் எங்கே?"

msgid "TXT_DLG_SCRIPT04_D37900_IFYOU"
msgstr "நீங்கள் வேலைக்குச் செல்லவில்லை என்றால், நீங்கள் எப்படியும் சுடப்படுவீர்கள். உங்கள் ஆடையை நகர்த்தவும்."

# MAP04: Reactor Core → Northern alarm green door
msgid "TXT_DLG_SCRIPT04_D39416_IDONT"
msgstr "அலாரம் ஒலிக்க வேண்டும் என்று நான் நினைக்கவில்லை, ஆனால் அவர்கள் ஆற்றல் படிகத்தை இவ்வளவு கடினமாகத் தள்ளினால், அது குறைபாடாகிவிடும், பின்னர் சிதைந்துவிடும், பின்னர் *பூம்*! …ஒரு சிந்தனை."

# MAP04: Reactor Core → Southern alarm green door
msgid "TXT_DLG_SCRIPT04_D40932_LETME"
msgstr "நான் தெளிவாக இருக்கட்டும். இந்த முனையம் மீண்டும் பூட்டப்பட்டால், குளிரூட்டும் நிலை குறையும், மேலும் நாம் அனைவரும் புரோகிராமரிடம் பதிலளிக்க வேண்டும். நாம் பிழைத்தால்."

# MAP04: Ketrick.
msgid "TXT_DLG_SCRIPT04_D42448_YOUYE"
msgstr "நீ! ஆமாம், நீங்கள். இந்தப் பகுதிக்கு நீங்கள் அனுமதிக்கப்படவில்லை. சீக்கிரம் உங்கள் திறவுகோல் அட்டையை என்னிடம் கொடுங்கள். நான் மிகவும் மோசமான மனநிலையில் இருக்கிறேன்!"

msgid "TXT_RPLY0_SCRIPT04_D42448_HEREH"
msgstr "இதோ, இதோ என் அட்டை."

msgid "TXT_DLG_SCRIPT04_D43964_THISI"
msgstr "இது குப்பை! இங்கே காத்திருங்கள். ஓ திருக்குறள். இந்த ஊடுருவும் நபரை காவலர்கள் கொன்றனர்!"

# MAP04: Reactor Core → Sammis
msgid "TXT_DLG_SCRIPT04_D45480_WORKS"
msgstr "வேலை, தூக்கம், சித்திரவதை, என்ன வாழ்க்கை. கவனக்குறைவான குழி மூழ்குபவருக்கு நீங்கள் மாற்று என்று சொல்லுங்கள்?"

msgid "TXT_RPLY0_SCRIPT04_D45480_YEAHC"
msgstr "ஆம், தொடங்குவதற்கு காத்திருக்க முடியாது."

msgid "TXT_DLG_SCRIPT04_D46996_YEAHR"
msgstr "ஆமாம், சரி. சரி, உங்கள் கழுதையை வேலைக்குச் செல்லுங்கள்."

msgid "TXT_RPLY0_SCRIPT04_D46996_WHERE"
msgstr "ச்படிகம் எங்கே?"

msgid "TXT_DLG_SCRIPT04_D48512_GOTAL"
msgstr "கெட்ரிக்கிடம் பேசுங்கள். சுவிட்சுகளைப் பயன்படுத்தி நடைபாதையை மேலே கொண்டு வாருங்கள், பிறகு இந்த ஐடியைப் பயன்படுத்தவும். லிஃப்ட்டுக்கு."

msgid "TXT_RPLY0_SCRIPT04_D48512_WHERE"
msgstr "மீண்டும் படிகம் எங்கே?"

msgid "TXT_DLG_SCRIPT04_D50028_NONEO"
msgstr "உங்கள் வேலை எதுவும் இல்லை, கெட்ரிக் உடன் பேசுங்கள்."

msgid "TXT_RPLY0_SCRIPT04_D50028_OK"
msgstr "சரி"

# (bored to tears = extremely bored)
msgid "TXT_DLG_SCRIPT04_D51544_IFITS"
msgstr "நீங்கள் விரும்பும் வேலையில் பிசியாக இருந்தால், அந்தத் திரையை சிறிது நேரம் உற்றுப் பாருங்கள், அது உங்களை அலுத்துவிடும்."

# MAP04: Reactor Core → Southern alarm green door
msgid "TXT_DLG_SCRIPT04_D53060_THEAL"
msgstr "சர்வவல்லமையுள்ள ப்ரோக்ராமர், கணினியின் மையப் பகுதியைப் பூட்டி விட்டார். எனது வேலையை நான் எப்படிச் செய்ய வேண்டும்? தற்கொலை ஓட்டம்தான் ஒரே வழி."

msgid "TXT_RPLY0_SCRIPT04_D53060_SUICI"
msgstr "தற்கொலை ஓட்டமா? அது என்ன?"

msgid "TXT_DLG_SCRIPT04_D54576_ITSAS"
msgstr "கொல்லப்படுவதற்கு இது ஒரு உறுதியான வழி, ஆனால் அது இப்போது முக்கியமில்லை. நீங்கள் மிகவும் சாய்ந்திருந்தால் லிப்டில் கீழே செல்லுங்கள்."

# MAP05: Door Guard.
msgid "TXT_DLG_SCRIPT05_D0_HALTN"
msgstr "நிறுத்து. வார்டன் அல்லது கவர்னர் அனுமதியின்றி யாரும் இங்கு வருவதில்லை."

msgid "TXT_RPLY0_SCRIPT05_D0_HERES"
msgstr "இதோ என் பாச், என்னை உள்ளே விடு."

msgid "TXT_DLG_SCRIPT05_D1516_OKBUT"
msgstr "சரி, ஆனால் வார்டனிடம் மட்டும் பேசுங்கள்."

# (After killing Montag)
msgid "TXT_DLG_SCRIPT05_D3032_DOILO"
msgstr "நான் உங்களுக்கு வார்டன் போல் இருக்கிறேனா? தொடர்ந்து நகரவும், இந்தப் பகுதி வரம்பற்றது."

# MAP05: Prison Guard.
msgid "TXT_DLG_SCRIPT05_D4548_THEOR"
msgstr "ஆணைக் சினம் இந்த அடியார்கள் மீது சாவை வேண்டி நிற்கும் வரை பொழியும்."

# MAP05: Montag.
msgid "TXT_DLG_SCRIPT05_D6064_IDONT"
msgstr "மோரல் உங்களுக்கு பாச் கொடுத்தாலும் எனக்கு கவலையில்லை. இது என் சிறை. எனது திறவுகோல் உள்ளே அல்லது வெளியே செல்லும் ஒரே வழி, நான் எந்த வாய்ப்புகளையும் எடுக்கவில்லை. ஆணை தவறுகளை பொறுத்துக்கொள்ளாது."

msgid "TXT_RPLY0_SCRIPT05_D6064_GIVEM"
msgstr "அட சாவியைக் கொடு!"

msgid "TXT_DLG_SCRIPT05_D7580_OVERM"
msgstr "என் இறந்த உடலின் மேல்!"

msgid "TXT_RPLY0_SCRIPT05_D7580_GREAT"
msgstr "அருமையான யோசனை!"

msgid "TXT_DLG_SCRIPT05_D9096_SHACK"
msgstr "சங்கிலிகள் அல்லது சங்கிலிகள், நீங்கள் சுற்றித் தொங்க வேண்டும் என்று நான் விரும்புகிறேன்."

# MAP05: Wolenick.
msgid "TXT_DLG_SCRIPT05_D10612_IDONT"
msgstr "காவலர்களையும் வார்டனையும் நீங்கள் எவ்வாறு கடந்து சென்றீர்கள் என்று எனக்குத் தெரியவில்லை, ஆனால் நீங்கள் இப்போது உள்ளே சென்றதால் அலங்காரத்தை நீங்கள் விரும்புவீர்கள் என்று நம்புகிறேன்."

msgid "TXT_RPLY0_SCRIPT05_D10612_FREEM"
msgstr "என் தோழர்களை விடுவிக்கவும் அல்லது இறக்கவும்!"

msgid "TXT_DLG_SCRIPT05_D12128_KILLM"
msgstr "என்னைக் கொல்லுங்கள், நீங்கள் யாரையும் விடுவிக்க மாட்டீர்கள். கலங்களைத் திறக்கும் ஒரே மாதிரி விசை என்னிடம் உள்ளது."

msgid "TXT_RPLY0_SCRIPT05_D12128_CANYO"
msgstr "அப்படியானால் எனக்கு ஒரு கை கொடுக்க முடியுமா?"

msgid "TXT_DLG_SCRIPT05_D13644_MOVEA"
msgstr "உடன் செல்லுங்கள் அல்லது உங்கள் நண்பர்களுடன் சேருங்கள்."

# MAP05: Prisoner.
msgid "TXT_DLG_SCRIPT05_D15160_DONTJ"
msgstr "அங்கே நிற்காதே, எங்களை இங்கிருந்து வெளியேற்று!"

msgid "TXT_DLG_SCRIPT05_D16676_THESK"
msgstr "வானம், நான் வானத்தைப் பார்க்க விரும்புகிறேன்."

msgid "TXT_DLG_SCRIPT05_D18192_FIVEF"
msgstr "ஐந்தடி நான்கு அடி, ஐந்தடி நான்கு அடி, ஐந்தடி நான்கு அடி."

msgid "TXT_DLG_SCRIPT05_D19708_DONTR"
msgstr "கட்டளை இன்னும் பொறுப்பில் இருந்தால் என்னை விடுவிக்க வேண்டாம். என்னால் பயங்கரத்தை தாங்க முடியவில்லை."

msgid "TXT_DLG_SCRIPT05_D21224_IDONT"
msgstr "நான் பிட்ச் செய்ய விரும்பவில்லை, ஆனால் எங்களை வெளியேற்றுவதற்கு Macil ஒருவரை அனுப்பிய நேரம் இது."

msgid "TXT_DLG_SCRIPT05_D22740_IDGIV"
msgstr "நான் ஒரு ரொட்டிக்கு எதையும் கொடுப்பேன். எனக்கு மிகவும் பசியாக இருக்கிறது."

# MAP06: Weran.
msgid "TXT_DLG_SCRIPT06_D0_AHASU"
msgstr "ஆ, ஒரு உதவி தேவைப்படுபவர். இங்கே கீழே நீங்கள் ஒரு உதவியைப் பெற ஒரு உதவி செய்கிறீர்கள், எனக்கு நகர நுழைவாயில் தேவை, அது எங்கள் உணவுக்கான பாதையாகும். கட்டளை சீல் வைக்கப்பட்டு பாதுகாக்கப்பட்டுள்ளது."

msgid "TXT_RPLY0_SCRIPT06_D0_WHERE"
msgstr "வாயில் பொறிமுறை எங்கே?"

msgid "TXT_DLG_SCRIPT06_D1516_DOMYF"
msgstr "முதலில் எனக்கு உதவி செய், இல்லையேல் என்னிடமிருந்து நீ குந்தியிருப்பாய்."

msgid "TXT_RPLY0_SCRIPT06_D1516_HOWWI"
msgstr "அது திறந்திருப்பது உங்களுக்கு எப்படித் தெரியும்?"

msgid "TXT_DLG_SCRIPT06_D3032_BRING"
msgstr "காவலாளியின் சீருடையை என்னிடம் கொண்டு வா. அந்த வகையில் எனது ராட்ஃபெலோக்களில் ஒருவர் அதை அணியலாம், யாரும் மீண்டும் கதவை மூட முயற்சிக்க மாட்டார்கள்."

msgid "TXT_RPLY0_SCRIPT06_D3032_YOUWA"
msgstr "அவனுடைய சீருடை உனக்கு வேண்டுமா?"

msgid "TXT_DLG_SCRIPT06_D4548_OPENT"
msgstr "கதவைத் திற, எனக்கு சீருடை கொண்டு வாருங்கள், நாங்கள் வணிகம் செய்கிறோம். இல்லையெனில், சினம்."

msgid "TXT_DLG_SCRIPT06_D6064_HAVEY"
msgstr "எனக்கு வேண்டியதை நீங்கள் கொண்டு வந்தீர்களா?"

msgid "TXT_RPLY0_SCRIPT06_D6064_HOWAB"
msgstr "இந்த சீருடை எப்படி இருக்கும்?"

msgid "TXT_RNO0_SCRIPT06_D6064_BRING"
msgstr "எனக்கு சீருடை கொண்டு வா."

# MAP06: Weran.
msgid "TXT_DLG_SCRIPT06_D7580_GOODH"
msgstr "நல்லது. இங்கே கூடுதல் ஒன்று உள்ளது. வீழ்ந்த சிலுவைப்போரின் இதை என் தோழர்கள் கிழித்து எறிந்தனர், இது ஒரு ஃபிளமேத்ரோவரை உருவாக்கும் பாகங்கள். இப்போது இரலே உங்களுக்காக ஒன்றை உருவாக்க முடியும். நீங்கள் அத்தகைய வேடிக்கையாக இருக்க முடியும்."

msgid "TXT_RPLY0_SCRIPT06_D7580_WHERE"
msgstr "கேட் மெக்கானிசம் எங்கே?"

#
# https://en.wikipedia.org/wiki/Reclaimed_water
msgid "TXT_DLG_SCRIPT06_D9096_YOUHA"
msgstr "சாக்கடையின் மற்றொரு பகுதிக்குள் நுழைய வேண்டும். அங்கு செல்ல, நீங்கள் ஒரு கழிவுநீர் பராமரிப்பு கதவில் இருந்து கோட்டைக்குள் நுழைந்து திரவ மீட்பு தொட்டியை வடிகட்ட வேண்டும். கீழே சாக்கடைக்கான மறைக்கப்பட்ட நுழைவாயில் உள்ளது, அதற்கு அப்பால் கையேடு கேட் கட்டுப்பாடு உள்ளது."

msgid "TXT_RPLY0_SCRIPT06_D9096_ANYTH"
msgstr "நீங்கள் வேறு ஏதாவது செய்ய முடியுமா?"

msgid "TXT_DLG_SCRIPT06_D10612_GOODL"
msgstr "நல்ல அதிர்ச்டம். உங்களுக்காக எங்களின் பல சுரங்கப்பாதைகளைத் திறந்துவிட்டேன். இது உங்கள் பணியை எளிதாக்க வேண்டும். ஓ, அளவு பத்து, சரியானது! ஆனால் பயங்கரமான நிறங்கள்."

msgid "TXT_RPLY0_SCRIPT06_D10612_THANK"
msgstr "உங்கள் உதவிக்கு நன்றி."

msgid "TXT_DLG_SCRIPT06_D12128_YOUGI"
msgstr "நீங்கள் எனக்கு எதுவும் கொடுக்கவில்லை, உங்களுக்கு எதுவும் கிடைக்காது."

# MAP06: Beggar.
msgid "TXT_DLG_SCRIPT06_D13644_WERAN"
msgstr "வேரன் நம்மைக் காப்பாற்றுவான். அவர் இதுவரை எங்களைத் தவறவிட்டதில்லை."

msgid "TXT_DLG_SCRIPT06_D15160_IFYOU"
msgstr "உங்கள் பிரச்சனைக்கு விடை தேடினால், வேரானைக் கண்டுபிடி. "

msgid "TXT_DLG_SCRIPT06_D16676_LONGL"
msgstr "முன்னணி வாழ்வா? அதெல்லாம் அபத்தம். நாம் அனைவரும் இறக்க காத்திருக்கிறோம். "

msgid "TXT_DLG_SCRIPT06_D18192_WITHO"
msgstr "மேற்பரப்பிற்கு நாம் செல்லும் பாதை சீல் வைக்கப்பட்டதால், நமக்கு நாமே உணவளிக்கக் கூட முடியாது."

msgid "TXT_DLG_SCRIPT06_D19708_FOODD"
msgstr "உணவு, உங்களிடம் உணவு இருக்கிறதா? தயவுசெய்து எங்களுக்கு உதவுங்கள்."

# MAP06: Gray acolyte.
msgid "TXT_DLG_SCRIPT06_D21224_THISI"
msgstr "கைதிகளை தப்பியோட அனுமதித்ததற்கும், சாக்கடைகளை காத்ததற்கும் இதுவே எனது வெகுமதி. அவர்களை உடைத்த ஒருவரை நான் எப்போதாவது கண்டுபிடித்தால், நான் அவரை படுகொலை செய்வேன்."

# MAP06: Red acolyte.
msgid "TXT_DLG_SCRIPT06_D22740_WEVEG"
msgstr "அந்த சிறிய பிச்சைக்காரர்களை நாம் விரும்பும் இடத்தில் நாங்கள் பெற்றுள்ளோம். இன்னும் சில நாட்கள், அவர்கள் மறதிக்குள் பட்டினி கிடப்பார்கள்."

# MAP06: Near storage.
msgid "TXT_DLG_SCRIPT06_D24256_WHATS"
msgstr "உங்கள் இசைவு என்ன? இங்கு அங்கீகரிக்கப்படாத பணியாளர்கள் யாரும் அனுமதிக்கப்படுவதில்லை."

# MAP07: Red acolyte at the main entrance.
msgid "TXT_DLG_SCRIPT07_D0_WHATT"
msgstr "என்ன ஆச்சு? கதவுகளைத் திறந்தது யார்? முன்னறிவிப்பு ஒலி!!!"

# MAP07
msgid "TXT_DLG_SCRIPT07_D1516_THERE"
msgstr "சாக்கடைக்குள் மற்றொரு வழி இருக்கிறது, அந்த சுவிட்சை எறிந்துவிட்டு, மேலே சென்று மறுசீரமைப்பு தொட்டியை தூய்மை செய்யுங்கள்."

# MAP07: Hospital.
msgid "TXT_DLG_SCRIPT07_D3032_WHATT"
msgstr "என்ன ஆச்சு உன் சிக்கல். புரோகிராமர் தனது பார்வையாளர் அறையிலிருந்து வந்தால், நீங்கள் இறந்துவிட்டீர்கள்."

msgid "TXT_DLG_SCRIPT07_D4548_HEYYO"
msgstr "ஏய், நீங்கள் அங்கு செல்ல இசைவு இல்லை."

# MAP07: Computer room (northwest building).
msgid "TXT_DLG_SCRIPT07_D6064_PROGR"
msgstr "புரோகிராமர்? உனக்கு யார் சொன்னது? புரோகிராமர் இல்லை. அந்தக் கதை பல வருடங்களுக்கு முன்பே பரப்பப்பட்டது. முன்னணி உண்மையில் அந்த முட்டாள்தனத்தை நம்பியது என்று என்னிடம் சொல்லாதீர்கள். முட்டாள்கள்."

msgid "TXT_RPLY0_SCRIPT07_D6064_WELLW"
msgstr "சரி, உண்மை என்ன?"

msgid "TXT_DLG_SCRIPT07_D7580_ITOLD"
msgstr "எனக்குத் தெரிந்ததைச் சொன்னேன். நீங்கள் உங்கள் நேரத்தை வீணடிக்கிறீர்கள்."

# MAP07: Font soldier.
msgid "TXT_DLG_SCRIPT07_D9096_FIGHT"
msgstr "போராடுங்கள், செய் பெறுவோம். இந்த நாள் நமக்கு சொந்தமானதாக இருக்கும்!"

msgid "TXT_DLG_SCRIPT07_D10612_FIGHT"
msgstr "போராடுங்கள், செய் பெறுவோம். இந்த நாள் நமக்கு சொந்தமானதாக இருக்கும்!"

msgid "TXT_DLG_SCRIPT07_D12128_FIGHT"
msgstr "போராடுங்கள், செய் பெறுவோம். இந்த நாள் நமக்கு சொந்தமானதாக இருக்கும்!"

msgid "TXT_DLG_SCRIPT07_D13644_FIGHT"
msgstr "போராடுங்கள், செய் பெறுவோம். இந்த நாள் நமக்கு சொந்தமானதாக இருக்கும்!"

msgid "TXT_DLG_SCRIPT07_D15160_FIGHT"
msgstr "போராடுங்கள், செய் பெறுவோம். இந்த நாள் நமக்கு சொந்தமானதாக இருக்கும்!"

msgid "TXT_DLG_SCRIPT07_D16676_FIGHT"
msgstr "போராடுங்கள், செய் பெறுவோம். இந்த நாள் நமக்கு சொந்தமானதாக இருக்கும்!"

# MAP08: Northeast room.
msgid "TXT_DLG_SCRIPT08_D0_YOUKI"
msgstr "எல்லா காவலர்களையும் கொன்றாய். என்னை காயப்படுத்தாதே. இது ஒரு முட்டாள்தனமான சிந்தனை என்று நான் அவரிடம் சொன்னேன். உண்மையான ப்ரோக்ராமர் காப்பகத்தில் இருக்கிறார். இதோ, இந்த சாவியை எடு."

msgid "TXT_RPLY0_SCRIPT08_D0_YOURE"
msgstr "நீங்கள் தான் புரோகிராமர்!"

msgid "TXT_DLG_SCRIPT08_D1516_DOILO"
msgstr "நான் இறுதி அதிகாரத்தைப் பயன்படுத்துவதைப் போல் இருக்கிறேனா? ஆணை நம் அனைவரையும் பயன்படுத்துகிறது. இப்போது போ, நான் ஏற்கனவே இறந்துவிட்டேன்."

msgid "TXT_DLG_SCRIPT08_D3032_POWER"
msgstr "சக்திதான் முக்கியம்!"

# MAP10: Macil.
msgid "TXT_DLG_SCRIPT10_D0_GOODY"
msgstr "நல்லது, நீங்கள் மீண்டும் விழிப்புடன் இருக்கிறீர்கள். புரோகிராமர் கைவிடப்பட்ட அந்த உருப்படியை நீங்கள் கைப்பற்றியபோது, சில பயங்கரமான ரகசியங்களை நீங்கள் விடுவித்தீர்கள்."

msgid "TXT_RPLY0_SCRIPT10_D0_WHATK"
msgstr "என்ன மாதிரியான ரகசியங்கள். "

msgid "TXT_DLG_SCRIPT10_D1516_WEHAV"
msgstr "இந்த கருவி எங்கிருந்து வந்தது என்று எங்களுக்குத் தெரியாது, ஆனால் நாம் கண்டுபிடிக்க வேண்டும். நீங்கள் ஆர்டரில் இருந்து ஒன்றைப் பறித்துவிட்டீர்கள், ஆனால் எங்களிடம் ஐந்தும் இருக்க வேண்டும். எனது அறிவின் எல்லையை நாங்கள் அடைந்துவிட்டோம். ஆரக்கிளைத் தேடி, உதவி கேட்கவும்."

msgid "TXT_RPLY0_SCRIPT10_D1516_IMGON"
msgstr "எனக்கு மேலும் பொருட்கள் தேவைப்படும்."

msgid "TXT_DLG_SCRIPT10_D3032_HERES"
msgstr "இதோ கொஞ்சம் தங்கம். மருத்துவரையும் ஆயுதப் பயிற்சியாளரையும் சென்று பார்த்துவிட்டு, வெளியே செல்லுங்கள்!"

msgid "TXT_RPLY0_SCRIPT10_D3032_RIGHT"
msgstr "சரி!"

msgid "TXT_DLG_SCRIPT10_D4548_FIGHT"
msgstr "முன்னணி மற்றும் சுதந்திரத்திற்காக போராடுங்கள். வெளியே செல்லவும்."

# MAP10: Macil → The Oracle said to kill him
msgid "TXT_DLG_SCRIPT10_D6064_WHATP"
msgstr "நீங்கள் திரும்புவதற்கு எது தூண்டுகிறது? நீங்கள் காயப்பட்டீர்களா? இழக்க நேரமில்லை, உங்கள் பணியைத் தொடருங்கள். சிகில் முடிக்கவும்."

msgid "TXT_RPLY0_SCRIPT10_D6064_THEOR"
msgstr "நீங்கள் இறக்க வேண்டும் என்று ஆரக்கிள் சொல்கிறது!"

msgid "TXT_DLG_SCRIPT10_D7580_IHAVE"
msgstr "நான் சுதந்திரத்திற்கு வாய்மை செய்தேன். மூன்றாவது பாகத்தை வைத்திருப்பது ஆரக்கிள்தான். உன் துரோகி இருக்கிறான்."

msgid "TXT_RPLY0_SCRIPT10_D7580_THEOR"
msgstr "அப்போது ஆரக்கிள் இறந்துவிடும்!"

msgid "TXT_RPLY1_SCRIPT10_D7580_ITHIN"
msgstr "நீங்கள் துரோகி என்று நினைக்கிறேன்!"

# MAP10: Macil → You chose to kill Macil
msgid "TXT_DLG_SCRIPT10_D9096_SPIRI"
msgstr "ஒரே கடவுளின் ஆவி என்னைப் பழிவாங்கும் மற்றும் இந்த உலகத்தை மண்ணாக மாற்றும்."

# MAP10: Macil → You chose to kill the Oracle
msgid "TXT_DLG_SCRIPT10_D10612_YOUHA"
msgstr "சரியான முடிவை எடுத்துள்ளீர்கள். ஆரக்கிள் ஒழுங்கை இயக்கும் எந்த தீமையால் கட்டுப்படுத்தப்படுகிறது என்பது தெளிவாகிறது. அதற்குத் திரும்பி, சிகிலின் மூன்றாவது பகுதியைக் கோருங்கள்."

# MAP10: Macil → After killing the Oracle
msgid "TXT_DLG_SCRIPT10_D12128_THERE"
msgstr "நாம் எதிர்கொள்ளும் பயங்கரத்திற்கு முடிவே இல்லை. ஆணை எங்கள் மக்களைக் கொல்லவில்லை என்பதை நாங்கள் கண்டுபிடித்துள்ளோம். அது அவர்களை உயிரி இயந்திர வீரர்களாக மாற்றுகிறது. இது செய்யப்படும் வசதியைக் கண்டறிந்து நிரந்தரமாக மூடவும்."

msgid "TXT_RPLY0_SCRIPT10_D12128_WHERE"
msgstr "இது எங்கே அமைந்துள்ளது?"

msgid "TXT_DLG_SCRIPT10_D13644_ONEOF"
msgstr "எங்கள் கேப்டன்களில் ஒருவரான ரிக்டர், காமன்சில் உள்ள நீர்வீழ்ச்சியில் உங்களுக்காகக் காத்திருக்கிறார். அவர் வசதியைப் பார்த்தார், உங்களை உள்ளே வழிநடத்துவார். இனியாவது இந்தக் கொடுமையை நிறுத்துங்கள்."

msgid "TXT_RPLY0_SCRIPT10_D13644_THEYL"
msgstr "இதற்கு அவர்கள் பணம் கொடுப்பார்கள்!"

msgid "TXT_DLG_SCRIPT10_D15160_FIGHT"
msgstr "முன்னணி மற்றும் சுதந்திரத்திற்காக போராடுங்கள். வெளியே செல்லவும்."

# MAP10: Macil → After destroying the converter in MAP24.
msgid "TXT_DLG_SCRIPT10_D16676_IAMTH"
msgstr "நான் ஒரு கடவுள்... நான் என் உடலை விட்டு வெளியேறி, அவருடன் சேர்ந்து பறப்பதற்கு அவருடைய ஆவி சுதந்திரமாக இருக்க வேண்டும். உங்களிடம் என்ன இருக்கிறது என்று உங்களுக்குத் தெரியாது... மேலும் நீங்கள் என்ன பயங்கரத்தை எதிர்கொள்கிறீர்கள்... ஒரே கடவுள் சுதந்திரமாக இருக்க வேண்டும்... அவர் எனக்கு வெகுமதி அளிப்பார்... நான் ஒருவனாக இருப்பேன்."

msgid "TXT_RPLY0_SCRIPT10_D16676_IWILL"
msgstr "நான் உன்னை அழிப்பேன்!"

# MAP10: Gerald (no upgrade).
msgid "TXT_DLG_SCRIPT10_D18192_GLADT"
msgstr "நீங்கள் செய்து பார்த்ததில் மகிழ்ச்சி. உனக்கு என்ன வேண்டும்? "

msgid "TXT_RPLY0_SCRIPT10_D18192_HEALM"
msgstr "என்னை குணமாக்குங்கள்."

msgid "TXT_RYES0_SCRIPT10_D18192_WELLL"
msgstr "சரி, உங்களை சரிசெய்வோம்."

msgid "TXT_RNO0_SCRIPT10_D18192_YOURE"
msgstr "நீங்கள் நலமாக இருக்கிறீர்கள்."

msgid "TXT_RPLY1_SCRIPT10_D18192_ANYTH"
msgstr "ஏதாவது புதியதா?"

msgid "TXT_RYES1_SCRIPT10_D18192_YESIV"
msgstr "ஆம், உங்களுக்காக சில புதிய ஆர்டுவேர் வைத்துள்ளேன்."

msgid "TXT_RNO1_SCRIPT10_D18192_NOPEI"
msgstr "இல்லை, நான் அதில் வேலை செய்கிறேன்."

# (one upgrade: Mission to talk to the Oracle)
msgid "TXT_DLG_SCRIPT10_D19708_WHATC"
msgstr "நான் இப்போது உனக்கு என்ன செய்ய முடியும்? ஃபெரிச் சில சிக்கலான கோப்புகளை டிக்ரிப்ட் செய்கிறார், ஆனால் அது மதிப்புக்குரியது. ச்டாமினா இம்ப்லான்ட்டின் அடுத்த பதிப்பிற்கு நான் விண்ணப்பிக்கக்கூடிய சில தகவல்கள் ஏற்கனவே உள்ளன."

msgid "TXT_RPLY0_SCRIPT10_D19708_HEALM"
msgstr "என்னை குணமாக்குங்கள்."

msgid "TXT_RYES0_SCRIPT10_D19708_YOUSH"
msgstr "நீங்கள் கொஞ்சம் கவனமாக இருக்க கற்றுக்கொள்ள வேண்டும்."

msgid "TXT_RPLY1_SCRIPT10_D19708_WHENW"
msgstr "அது எப்போது தயாராகும்?"

msgid "TXT_RYES1_SCRIPT10_D19708_ITSRE"
msgstr "அது இப்போது தயாராக உள்ளது. இதற்கு ஒரு கணம் மட்டுமே ஆகாது."

msgid "TXT_RNO1_SCRIPT10_D19708_SOON"
msgstr "விரைவில்."

# (two upgrades: Mission to decide between Macil or the Oracle)
msgid "TXT_DLG_SCRIPT10_D21224_ITHIN"
msgstr "உங்கள் உள்வைப்பு வன்பொருளில் ஒரு கோளாறைக் கண்டேன் என்று நினைக்கிறேன். ஃபெரிச் எனக்கு ஒரு ரெட்ரோஃபிட்டை வடிவமைக்க உதவுகிறார், அது அதை கவனித்து உங்கள் வன்பொருளின் வேகத்தை சிறிது அதிகரிக்கும். உங்களுக்காக நான் ஏதாவது செய்ய முடியுமா?"

msgid "TXT_RPLY0_SCRIPT10_D21224_PATCH"
msgstr "என்னை ஒட்டவும்."

msgid "TXT_RYES0_SCRIPT10_D21224_THERE"
msgstr "அங்கு, புதியது போல் நல்லது என்று நான் நினைக்கிறேன்."

msgid "TXT_RPLY1_SCRIPT10_D21224_RETRO"
msgstr "ரெட்ரோஃபிட்டா?"

# (during sad/bad ending)
msgid "TXT_RYES1_SCRIPT10_D21224_AHNOW"
msgstr "ஆ, இப்போது நாங்கள் சமைக்கிறோம்."

msgid "TXT_RNO1_SCRIPT10_D21224_ILLHA"
msgstr "ஃபெரிச் முடிச்சதும் வாங்கிடறேன்."

# (three upgrades: Mission to kill the Loremaster with the Oracle alive).
msgid "TXT_DLG_SCRIPT10_D22740_HOWSI"
msgstr "எப்படி போகிறது? மனிதனே, இந்த புதிய தொழில்நுட்பத்தில் சில வெறுமனே ஆச்சரியமாக இருக்கிறது. இது உங்கள் உள்வைப்புக்கு உதவ வேண்டும். நான் சில யோசனைகளை உருவாக்கிக்கொண்டிருக்கிறேன், விரைவில் அவற்றை ஆயத்தம் செய்வேன். நான் உங்களுக்காக என்ன செய்ய முடியும், ஒருவேளை ஏதாவது குணப்படுத்த முடியுமா?"

msgid "TXT_RPLY0_SCRIPT10_D22740_YESHE"
msgstr "ஆம், என்னை குணமாக்குங்கள்."

msgid "TXT_RYES0_SCRIPT10_D22740_ALLRI"
msgstr "சரி, இதோ."

msgid "TXT_RPLY1_SCRIPT10_D22740_HOWAB"
msgstr "அந்த புதிய தொழில்நுட்பம் எப்படி இருக்கும்?"

msgid "TXT_RYES1_SCRIPT10_D22740_LETME"
msgstr "இது எப்படி வேலை செய்கிறது என்பதை எனக்குத் தெரியப்படுத்துங்கள்."

msgid "TXT_RNO1_SCRIPT10_D22740_IMNOT"
msgstr "நான் இன்னும் அதை வடிவமைத்து முடிக்கவில்லை."

# (four upgrades).
msgid "TXT_DLG_SCRIPT10_D24256_BACKA"
msgstr "மீண்டும், நீங்கள் இதை ஒருபோதும் சோர்வடையவில்லையா? எனக்கு சில நல்ல செய்திகள் கிடைத்துள்ளன, உங்கள் உள்வைப்பின் வெளியீட்டை அதிகரிக்க ஃபெரிச் ஒரு வழியைக் கண்டுபிடித்தார். அவர் விவரக்குறிப்புகளை என்னிடம் கொடுத்தார், நான் அதை உங்கள் உடலியலுடன் கலக்க முயற்சிக்கிறேன். நான் சில திசுவை வலுக்கட்டாயமாக வளர்த்து வருகிறேன், முற்றிலும் புதிய விசயங்கள், அது எடுக்கும் என்று நம்புகிறேன். உங்களுக்கு மருத்தீடு தேவையா?"

msgid "TXT_RPLY0_SCRIPT10_D24256_YESHE"
msgstr "ஆம், என்னை குணமாக்குங்கள்."

msgid "TXT_RYES0_SCRIPT10_D24256_DONEN"
msgstr "முடிந்தது, இப்போது உங்களை கவனித்துக் கொள்ளுங்கள்."

msgid "TXT_RPLY1_SCRIPT10_D24256_WHENW"
msgstr "நீங்கள் எப்போது முடிப்பீர்கள்?"

msgid "TXT_RYES1_SCRIPT10_D24256_NOWHE"
msgstr "இப்போது. ஏய், அது வேலை செய்தது!"

msgid "TXT_RNO1_SCRIPT10_D24256_IMWAI"
msgstr "திசுக்களின் வளர்ச்சி சுழற்சியை முடிக்க நான் காத்திருக்கிறேன்."

# (five upgrades).
msgid "TXT_DLG_SCRIPT10_D25772_WELLI"
msgstr "சரி, நான் மீண்டும் எனது பழைய தந்திரங்களுக்கு திரும்பினேன், நான் இன்னும் உங்கள் உள்வைப்புகளில் வேலை செய்து வருகிறேன். Macil இப்போது அனைவருக்கும் அவற்றை அங்கீகரித்துள்ளது என்பது உங்களுக்குத் தெரியுமா? இல்லை, இல்லையா? ஏனென்றால் நீங்கள் நன்றாக வந்தீர்கள். உங்களுக்காக நான் ஏதாவது செய்ய முடியுமா?"

msgid "TXT_RPLY0_SCRIPT10_D25772_HELPM"
msgstr "இங்கே எனக்கு உதவுங்கள்."

msgid "TXT_RYES0_SCRIPT10_D25772_THATS"
msgstr "என்னால் முடியும் அவ்வளவுதான்."

msgid "TXT_RPLY1_SCRIPT10_D25772_NEWIM"
msgstr "புதிய உள்வைப்பு?"

msgid "TXT_RYES1_SCRIPT10_D25772_YEPMY"
msgstr "ஆம், இன்னும் என்னுடைய சிறந்த ஒன்று."

msgid "TXT_RNO1_SCRIPT10_D25772_SORRY"
msgstr "மன்னிக்கவும், ஆனால் நீங்கள் காத்திருக்க வேண்டும்."

# (six upgrades).
msgid "TXT_DLG_SCRIPT10_D27288_THISI"
msgstr "இதுதான், ஃபெரிச் எங்களிடம் உள்ள எல்லா தரவுகளிலிருந்தும் தன்னால் முடிந்த அனைத்தையும் வெளியேற்ற முடிந்தது, இது சிறந்த மற்றும் கடைசி உள்வைப்பு மேம்படுத்தலாக இருக்கும். எனது சிறந்த படைப்பு அதன் உச்சத்தை எட்டுவதைப் பார்க்கும்போது அது ஒருவித மனச்சோர்வை ஏற்படுத்தும். சரி, குறைந்த பட்சம் இந்த குழுவினர் என்னை ஆக்கிரமித்து வைத்திருப்பார்கள்."

msgid "TXT_RPLY0_SCRIPT10_D27288_COULD"
msgstr "நீங்கள் என்னை குணப்படுத்த முடியுமா?"

msgid "TXT_RYES0_SCRIPT10_D27288_THERE"
msgstr "அங்கே, நீங்கள் இப்போது தயாராகிவிட்டீர்கள்."

# MAP10: Feris (no training).
msgid "TXT_DLG_SCRIPT10_D28804_ITSTH"
msgstr "அது ஈரோ. பெரிய வேலை! நான் உங்களுக்காக என்ன பெற முடியும்? எங்களிடம் கோட்டையிலிருந்து அனைத்து ஒழுங்குமுறைகளும் இருப்பதால் இப்போது கொஞ்சம் பெரிய தேர்வைப் பெற்றுள்ளோம். நீங்கள் வெடிமருந்து வாங்க வேண்டும் என்றால் சச்டினிடம் பேசுங்கள். அவர் உங்களை கவனித்துக் கொள்வார். "

msgid "TXT_RPLY0_SCRIPT10_D28804_IMOUT"
msgstr "எனக்கு குண்டுகள் தீர்ந்துவிட்டது."

msgid "TXT_RYES0_SCRIPT10_D28804_HERES"
msgstr "இதோ உங்களுக்காக சில வெடிமருந்துகள். அதை வீணாக்காதீர்கள்."

msgid "TXT_RPLY1_SCRIPT10_D28804_TEACH"
msgstr "எனக்கு கற்றுக்கொடுங்கள்."

msgid "TXT_RYES1_SCRIPT10_D28804_NOWAF"
msgstr "இப்போது, பெரிய துப்பாக்கிகள் பற்றிய சில குறிப்புகள்."

msgid "TXT_RNO1_SCRIPT10_D28804_YOURE"
msgstr "நீங்கள் இன்னும் தயாராகவில்லை."

# (one training)
msgid "TXT_DLG_SCRIPT10_D30320_HOWST"
msgstr "போர் முயற்சி எப்படி இருக்கிறது? பரவாயில்லை, நாங்கள் இன்னும் இங்கே இருந்தால், அது நன்றாக இருக்கும். நான் உனக்கு என்ன செய்ய முடியும்?"

msgid "TXT_RPLY0_SCRIPT10_D30320_IRANO"
msgstr "எனக்கு தோட்டாக்கள் தீர்ந்தன."

msgid "TXT_RYES0_SCRIPT10_D30320_THATS"
msgstr "அது உதவ வேண்டும்."

msgid "TXT_RNO0_SCRIPT10_D30320_YOUVE"
msgstr "உங்களிடம் போதுமான வெடிமருந்துகள் உள்ளன."

msgid "TXT_RPLY1_SCRIPT10_D30320_TEACH"
msgstr "எனக்கு கற்றுக்கொடுங்கள்."

msgid "TXT_RYES1_SCRIPT10_D30320_HEREI"
msgstr "இங்கே, நான் வர்த்தகத்தின் சில தந்திரங்களைக் காட்டுகிறேன்."

msgid "TXT_RNO1_SCRIPT10_D30320_YOURE"
msgstr "நீங்கள் இன்னும் தயாராகவில்லை."

# (two trainings)
msgid "TXT_DLG_SCRIPT10_D31836_WELLH"
msgstr "நீங்கள் பயிற்சிக்காக வந்திருக்கிறீர்களா அல்லது நீங்கள் தேடும் வெடிமருந்துகளா? நான் உன்னை இன்னும் முடித்துவிட்டேன் என்று நினைக்காதே. நான் இன்னும் சில தந்திரங்களை வைத்திருக்கிறேன்."

msgid "TXT_RPLY0_SCRIPT10_D31836_ITSAM"
msgstr "இது இப்போதைக்கு வெடிமருந்து."

msgid "TXT_RYES0_SCRIPT10_D31836_HERES"
msgstr "இதோ உங்களுக்காக சில வெடிமருந்துகள். அதை வீணாக்காதீர்கள்."

msgid "TXT_RNO0_SCRIPT10_D31836_YOUVE"
msgstr "உங்களிடம் போதுமான வெடிமருந்துகள் உள்ளன."

msgid "TXT_RPLY1_SCRIPT10_D31836_TEACH"
msgstr "எனக்கு கற்றுக்கொடுங்கள்."

msgid "TXT_RYES1_SCRIPT10_D31836_TIMEF"
msgstr "மேம்பட்ட பாடங்களுக்கான நேரம்."

msgid "TXT_RNO1_SCRIPT10_D31836_YOURE"
msgstr "நீங்கள் இன்னும் தயாராகவில்லை."

# (three trainings)
msgid "TXT_DLG_SCRIPT10_D33352_WELLW"
msgstr "சரி, இப்போது அது என்ன? நீங்கள் எப்போதாவது ஓய்வு எடுக்கவேண்டாமா? நீங்கள் இன்னும் சுவாசிப்பதில் மகிழ்ச்சி அடைகிறேன். எனக்குப் பிடித்த மாணவன் உடல் பையின் உள்ளே இருந்து வெளியே திரும்பி வருவதை நான் வெறுக்கிறேன்."

msgid "TXT_RPLY0_SCRIPT10_D33352_INEED"
msgstr "எனக்கு இன்னும் சில தோட்டாக்கள் தேவை."

msgid "TXT_RYES0_SCRIPT10_D33352_THERE"
msgstr "அங்கே, அதை வீணாக்காதீர்கள்."

msgid "TXT_RNO0_SCRIPT10_D33352_YOUHA"
msgstr "உன்னிடம் போதும்."

msgid "TXT_RPLY1_SCRIPT10_D33352_WHATC"
msgstr "நீங்கள் எனக்கு என்ன கற்பிக்க முடியும்?"

msgid "TXT_RYES1_SCRIPT10_D33352_DONTG"
msgstr "சுறுசுறுப்பாக இருக்க வேண்டாம், நீங்கள் வளர இன்னும் சிறிது இடம் உள்ளது."

msgid "TXT_RNO1_SCRIPT10_D33352_NOTHI"
msgstr "நீங்கள் தயாராகும் வரை எதுவும் இல்லை."

# (four trainings)
msgid "TXT_DLG_SCRIPT10_D34868_LOOKW"
msgstr "திரும்பி வந்தவர் யார் என்று பாருங்கள், உங்கள் மனதில் என்ன இருக்கிறது? இது கடினமாக இருந்தது என்று எனக்குத் தெரியும், ஆனால் உங்கள் முயற்சிகளை நாங்கள் அனைவரும் பாராட்டுகிறோம், என்னை நம்புங்கள்."

msgid "TXT_RPLY0_SCRIPT10_D34868_IVERU"
msgstr "என்னிடம் தோட்டாக்கள் தீர்ந்துவிட்டன."

msgid "TXT_RYES0_SCRIPT10_D34868_WHATE"
