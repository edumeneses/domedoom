msgid "TXT_RNO3_SCRIPT02_D12128_COMEO"
msgstr "வாருங்கள், 200 தங்கம்!"

# MAP02: Between governor's mansion and town hall.
msgid "TXT_DLG_SCRIPT02_D13644_ICANT"
msgstr "இந்தக் கடமையில் நான் சிக்கிக்கொண்டதை என்னால் நம்ப முடியவில்லை. இந்த சாக்கடை வாயிலில் இருந்து ஏதோ தீமை வந்தது என்று சொல்கிறார்கள்... இப்போது அது மீண்டும் மேலே வரும் வரை நான் இங்கே நிற்கிறேன்!"

msgid "TXT_RPLY0_SCRIPT02_D13644_WHATG"
msgstr "என்ன வாசல்?"

msgid "TXT_RYES0_SCRIPT02_D13644_THESE"
msgstr "சாக்கடை நிரம்பி வழியும் கேட்."

# MAP02: Weapons.
msgid "TXT_DLG_SCRIPT02_D15160_HELLO"
msgstr "வணக்கம் நண்பரே. நான் உங்களுக்காக என்ன பெற முடியும்?"

msgid "TXT_RPLY0_SCRIPT02_D15160_ELECT"
msgstr "மின்சார போல்ட்கள்"

msgid "TXT_RYES0_SCRIPT02_D15160_YOUGO"
msgstr "நீங்கள் மின்சார போல்ட்களைப் பெற்றுள்ளீர்கள்."

msgid "TXT_RPLY1_SCRIPT02_D15160_AMMOS"
msgstr "வெடிமருந்து சாட்செல்"

msgid "TXT_RNO0_SCRIPT02_D15160_NOYOU"
