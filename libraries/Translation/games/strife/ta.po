msgid "TXT_RYES3_SCRIPT02_D9096_HERES"
msgstr "இதோ உங்கள் வெடிமருந்து."

msgid "TXT_RNO3_SCRIPT02_D9096_MAYBE"
msgstr "வேறு சில சமயம் இருக்கலாம். குட்பை!"

