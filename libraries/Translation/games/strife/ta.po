msgid "TXT_RNO0_SCRIPT10_D37900_YOUHA"
msgstr "உன்னிடம் போதும்."

msgid "TXT_RPLY1_SCRIPT10_D37900_TEACH"
msgstr "எனக்கு கற்றுக்கொடுங்கள்."

msgid "TXT_RYES1_SCRIPT10_D37900_WELLT"
msgstr "சரி, அவ்வளவுதான், நீங்கள் முடித்துவிட்டீர்கள். என்னால் இனி கற்பிக்க முடியாது."

