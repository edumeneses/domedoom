msgid "TXT_RNO1_SCRIPT10_D34868_NOTRI"
msgstr "இப்போது இல்லை."

# (five trainings)
msgid "TXT_DLG_SCRIPT10_D36384_WHATI"
msgstr "உங்களுக்கு என்ன தேவை? பல ஆண்டுகளாக நாங்கள் அனுபவித்து வரும் வலியை நீங்கள் ஆர்டருக்கு வழங்குகிறீர்கள் என்று நம்புகிறேன்."

msgid "TXT_RPLY0_SCRIPT10_D36384_SOMEA"
msgstr "சில வெடிமருந்துகள்."

msgid "TXT_RYES0_SCRIPT10_D36384_THERE"
