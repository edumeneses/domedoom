# MAP01: Beldin.
msgid "TXT_DLG_SCRIPT01_D0_IDONT"
msgstr "எனக்கு எந்த பிரச்சனையும் வேண்டாம், என்னை விட்டு விலகி இரு. அந்த பாச்டர்ட் ஆரிச் என்னை என்ன செய்தான் என்பதில் எனக்கு போதுமான தொல்லை இருந்தது. அவர் எனக்கு பணம் உறுதியளித்தார், அதற்கு பதிலாக நான் புரோகிராமரால் விசாரிக்கப்படுவதை எதிர்நோக்குகிறேன்."

# MAP02: Guy next to Norwall Prison.
msgid "TXT_DLG_SCRIPT02_D0_ILLHE"
msgstr "நீங்கள் எனக்கு உதவி செய்தால் நான் உங்களுக்கு உதவுவேன். ஐந்து தங்கக் காசுகள், எனக்குத் தெரிந்ததைச் சொல்கிறேன்."

msgid "TXT_RPLY0_SCRIPT02_D0_HERES"
msgstr "இதோ தங்கம்."

# (This text is only four seconds on screen)
msgid "TXT_RYES0_SCRIPT02_D0_BESTE"
msgstr "நீங்கள் கொல்லும்போது திருட்டுத்தனமாக இருங்கள், நீங்கள் அலாரங்களை அமைக்க மாட்டீர்கள்."

# (Four seconds)
msgid "TXT_RNO0_SCRIPT02_D0_WELLI"
msgstr "சரி, நான் உங்களுக்கு எதுவும் இலவசமாகச் சொல்ல மாட்டேன்!"

msgid "TXT_DLG_SCRIPT02_D1516_HAVEY"
msgstr "உங்களுக்கு இன்னும் 5 நல்ல வாய்ப்புகள் உள்ளதா?"

msgid "TXT_RPLY0_SCRIPT02_D1516_5GOLD"
msgstr "5 தங்கம்."

# (Four seconds)
msgid "TXT_RYES0_SCRIPT02_D1516_WELLP"
msgstr "நஞ்சு போல்ட்கள் காவலர்களை உடனடியாகக் கொல்லலாம் மற்றும் அலாரங்களை அமைக்காது."

# (Four seconds)
msgid "TXT_RNO0_SCRIPT02_D1516_NOSIR"
msgstr "இல்லை சார், நான் உங்களுக்கு எதுவும் இலவசமாக சொல்ல மாட்டேன்!"

msgid "TXT_DLG_SCRIPT02_D3032_YOUVE"
msgstr "நீங்கள் ஏற்கனவே என்னிடமிருந்து கிசுகிசுக்களின் கடைசி பகுதியை அகற்றிவிட்டீர்கள்!"

# MAP02: Irale.
msgid "TXT_DLG_SCRIPT02_D4548_WHATC"
msgstr "நான் உங்களுக்காக என்ன பெற முடியும்?"

msgid "TXT_RPLY0_SCRIPT02_D4548_ASSAU"
msgstr "தாக்குதல் துப்பாக்கி"

msgid "TXT_RYES0_SCRIPT02_D4548_HEREY"
msgstr "இதோ போ."

msgid "TXT_RNO0_SCRIPT02_D4548_YOUCA"
msgstr "உங்களால் இப்போது அதை வாங்க முடியாது."

msgid "TXT_RPLY1_SCRIPT02_D4548_CLIPO"
msgstr "தோட்டாக்களின் கிளிப்"

msgid "TXT_RYES1_SCRIPT02_D4548_THANK"
msgstr "நன்றி."

msgid "TXT_RNO1_SCRIPT02_D4548_COMEO"
msgstr "வாருங்கள், 10 தங்கம்."

msgid "TXT_RPLY2_SCRIPT02_D4548_AMMOB"
msgstr "வெடிமருந்து பெட்டி"

msgid "TXT_RYES2_SCRIPT02_D4548_HERES"
msgstr "இதோ உங்கள் வெடிமருந்து."

msgid "TXT_RNO2_SCRIPT02_D4548_MAYBE"
msgstr "வேறு சில சமயம் இருக்கலாம்."

# (After destroying the crystal in the Power Station)
msgid "TXT_DLG_SCRIPT02_D6064_GOODN"
msgstr "ஒரு மாற்றத்திற்கு முன்னணியில் இருந்து நல்ல செய்தி. மேசில் உங்களை வெகுமதி மற்றும் பயிற்சிக்காக அனுப்பியுள்ளார். அவற்றை உங்களுக்குக் கொடுக்கும்படி அவர் எனக்கு அறிவுறுத்தினார்."

msgid "TXT_RPLY0_SCRIPT02_D6064_THANK"
msgstr "நன்றி."

msgid "TXT_RYES0_SCRIPT02_D6064_GLADT"
msgstr "பணி செய்வதில் மகிழ்ச்சி."

msgid "TXT_DLG_SCRIPT02_D7580_ALLRI"
msgstr "சரி, என்ன செய்ய வேண்டும் என்பதற்கான சில குறிப்புகள் இங்கே உள்ளன: சிலுவைப்போர்களின் வழியில் வராதீர்கள்: உங்கள் தாக்குதல் துப்பாக்கியிலிருந்து சிறிய வெடிப்புகளை சுடுவது அதை இலக்கில் வைத்திருக்கும்."

msgid "TXT_RPLY0_SCRIPT02_D7580_ISTHA"
msgstr "அதுவா?"

msgid "TXT_RYES0_SCRIPT02_D7580_LOOKY"
msgstr "பாருங்கள், நீங்கள் பின்னர் மேலும் அறிந்து கொள்வீர்கள்."

msgid "TXT_DLG_SCRIPT02_D9096_ITHIN"
msgstr "க்ரூசேடர்களில் ஒன்றிலிருந்து ஒரு ஃபிளமேத்ரோவரை ஒரு மனிதனின் உபயோகத்திற்காக மாற்ற முடியும் என்று நினைக்கிறேன். ஓ, நான் உங்களுக்கு வேறு ஏதாவது கிடைக்குமா?"

msgid "TXT_RPLY0_SCRIPT02_D9096_FLAME"
msgstr "ஃபிளமேத்ரோவர்."

msgid "TXT_RYES0_SCRIPT02_D9096_IKNEW"
msgstr "அது வேலை செய்யும் என்று எனக்குத் தெரியும்! இதோ, அவளை ஒரு சுற்றுக்கு அழைத்துச் செல்லுங்கள்!"

msgid "TXT_RNO0_SCRIPT02_D9096_LISTE"
msgstr "கேளுங்கள், சரியான பாகங்கள் இல்லாமல் என்னால் எதையும் செய்ய முடியாது!"

msgid "TXT_RPLY1_SCRIPT02_D9096_ASSAU"
msgstr "தாக்குதல் துப்பாக்கி"

msgid "TXT_RYES1_SCRIPT02_D9096_WELLH"
msgstr "சரி, இதோ ஐயா!"

msgid "TXT_RNO1_SCRIPT02_D9096_OBVIO"
msgstr "வெளிப்படையாக, நீங்கள் இப்போது அதை வாங்க முடியாது."

msgid "TXT_RPLY2_SCRIPT02_D9096_CLIPO"
msgstr "தோட்டாக்களின் கிளிப்"

msgid "TXT_RYES2_SCRIPT02_D9096_THANK"
msgstr "நன்றி."

msgid "TXT_RNO2_SCRIPT02_D9096_COMEO"
