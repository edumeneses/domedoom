msgid "TXT_DLG_SCRIPT02_D9096_ITHIN"
msgstr "Думаю, я зможу модифікувати вогнемет Хрестоносців під людську руку. А, бажаєш ще чогось?"

msgid "TXT_RPLY0_SCRIPT02_D9096_FLAME"
