msgid "TXT_DLG_SCRIPT02_D6064_GOODN"
msgstr "Хоч якісь хороші новини з фронту для різноманітності. Масіл направив тебе по нагороду та інструктаж. Він доручив мені зайнятися цим."

msgid "TXT_RPLY0_SCRIPT02_D6064_THANK"
msgstr "Дякую."

msgid "TXT_RYES0_SCRIPT02_D6064_GLADT"
msgstr "Радий бути корисним."

#, fuzzy
msgid "TXT_DLG_SCRIPT02_D7580_ALLRI"
msgstr "Гаразд, ось тобі кілька порад: не ставай на шляху в Хрестоносців — стрільба короткими чергами з твоєї штурмової гвинтівки допомагає утримувати ціль."

msgid "TXT_RPLY0_SCRIPT02_D7580_ISTHA"
msgstr "Це все?"

msgid "TXT_RYES0_SCRIPT02_D7580_LOOKY"
