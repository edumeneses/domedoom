msgid "TXT_DLG_SCRIPT01_D0_IDONT"
msgstr "Відійди, я не шукаю проблем. Цей виродок Гарріс вже довів мене до ручки. Обіцяв платити, а тепер мені світить допит у Програміста."

msgid "TXT_DLG_SCRIPT02_D0_ILLHE"
msgstr "Якщо ти допоможеш мені — я допоможу тобі. П'ять золотих і я розкажу усе, що знаю."

msgid "TXT_RPLY0_SCRIPT02_D0_HERES"
msgstr "Ось золото."

msgid "TXT_RYES0_SCRIPT02_D0_BESTE"
msgstr "Убивай непомітно, так ти не піднімеш тривоги."

msgid "TXT_RNO0_SCRIPT02_D0_WELLI"
msgstr "Ну, безкоштовно я тобі нічого не скажу!"

msgid "TXT_DLG_SCRIPT02_D1516_HAVEY"
msgstr "У тебе, бува, не знайдеться ще 5 золотих?"

msgid "TXT_RPLY0_SCRIPT02_D1516_5GOLD"
msgstr "5 золотих."

msgid "TXT_RYES0_SCRIPT02_D1516_WELLP"
msgstr "Ну, отруйні болти вбивають охоронців миттєво і не піднімають тривоги."

msgid "TXT_RNO0_SCRIPT02_D1516_NOSIR"
msgstr "Ні пане, я не скажу тобі нічого безплатно!"

msgid "TXT_DLG_SCRIPT02_D3032_YOUVE"
msgstr "Та ти з мене вже всі чутки до останньої витяг!"

msgid "TXT_DLG_SCRIPT02_D4548_WHATC"
msgstr "Чого бажаєте?"

msgid "TXT_RPLY0_SCRIPT02_D4548_ASSAU"
